# Environment Variables — Tuinplatform
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to git.

# ── LaventeCare Auth ─────────────────────────────────────────────────────────
# API URL for the LaventeCare AuthSystem backend
PUBLIC_API_URL=https://laventecareauthsystems.onrender.com/api/v1
# TuinHub tenant ID
PUBLIC_TENANT_ID=05cbd9a2-2ef6-4314-9e02-7b718a630bf9

# ── Convex ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.convex.dev/ → your deployment → Settings
PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://YOUR-DEPLOYMENT.convex.site
# These are set in the Convex dashboard under Environment Variables:
# LAVENTECARE_API_URL=https://laventecareauthsystems.onrender.com/api/v1
# TENANT_ID=05cbd9a2-2ef6-4314-9e02-7b718a630bf9

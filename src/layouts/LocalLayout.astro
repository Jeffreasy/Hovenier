---
import BaseLayout from './BaseLayout.astro'
import Accordion from '../components/ui/Accordion.astro'
import type { SEOMeta, FAQItem, Stad } from '../lib/types'

interface Props {
  seo: SEOMeta
  stad: Stad
  aantalHoveniers?: number
  gemiddeldePrijs?: string
  faqs?: FAQItem[]
}

const {
  seo,
  stad,
  aantalHoveniers = 12,
  gemiddeldePrijs = '€45 – €75 per uur',
  faqs = [],
} = Astro.props

const localSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `TuinHub – Hoveniers in ${stad.naam}`,
  description: seo.description,
  areaServed: {
    '@type': 'City',
    name: stad.naam,
    containedInPlace: { '@type': 'AdministrativeArea', name: stad.provincie },
  },
  url: `https://www.tuinhub.nl/steden/${stad.slug}`,
})

const faqSchema = faqs.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
}) : undefined

const combinedSchema = [localSchema, faqSchema].filter(Boolean).join('\n')
---

<BaseLayout seo={seo} schema={combinedSchema}>
  <div class="local-layout">
    <!-- Hero -->
    <header class="local-hero">
      <div class="container">
        <div class="local-breadcrumb">
          <a href="/">Home</a> / <a href="/steden">Steden</a> / <span>{stad.naam}</span>
        </div>

        <h1 class="local-title">
          Hovenier in {stad.naam}
          <span class="local-title-sub">Vergelijk en vind de beste</span>
        </h1>

        <div class="local-stats">
          <div class="local-stat">
            <strong>{aantalHoveniers}+</strong>
            <span>hoveniers actief</span>
          </div>
          <div class="local-stat">
            <strong>{gemiddeldePrijs}</strong>
            <span>gemiddeld tarief</span>
          </div>
          <div class="local-stat">
            <strong>Gratis</strong>
            <span>offertes vergelijken</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Inline offerte formulier -->
    <section class="local-offerte section-gap">
      <div class="container">
        <div class="local-offerte-card">
          <h2>Vraag gratis offertes aan in {stad.naam}</h2>
          <p>Ontvang binnen 48 uur maximaal 3 offertes van hoveniers bij jou in de buurt.</p>
          <slot name="offerte-form" />
        </div>
      </div>
    </section>

    <!-- Dynamische lokale content -->
    <section class="local-content section-gap">
      <div class="container local-content-grid">
        <div class="prose">
          <slot name="content" />
        </div>
        <aside class="local-sidebar">
          <slot name="sidebar" />
        </aside>
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && (
      <section class="local-faq section-gap">
        <div class="container">
          <h2>Veelgestelde vragen over hoveniers in {stad.naam}</h2>
          <div class="local-faq-list">
            {faqs.map((faq) => (
              <Accordion question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  /* Hero: glass overlay op dark canvas, geen lichte gradient meer */
  .local-hero {
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 3.5rem 0;
  }

  .local-breadcrumb {
    font-size: 0.8125rem;
    color: rgba(237,242,236,0.35);
    margin-bottom: 1.5rem;
  }

  .local-breadcrumb a {
    color: rgba(237,242,236,0.45);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .local-breadcrumb a:hover { color: #EDF2EC; }

  .local-title {
    color: #EDF2EC;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 2rem;
  }

  .local-title-sub {
    font-size: 1.125rem;
    font-weight: 400;
    color: rgba(237,242,236,0.55);
  }

  .local-stats { display: flex; gap: 2.5rem; flex-wrap: wrap; }

  .local-stat { display: flex; flex-direction: column; gap: 0.125rem; }

  .local-stat strong {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-secondary);
  }

  .local-stat span {
    font-size: 0.78rem;
    color: rgba(237,242,236,0.45);
  }

  /* Offerte card: glass */
  .local-offerte-card {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: var(--radius-xl);
    padding: 2rem;
    max-width: 680px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.30);
  }

  .local-offerte-card h2 { margin-top: 0; color: #EDF2EC; }
  .local-offerte-card p { color: rgba(237,242,236,0.58); }

  .local-content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .local-content-grid { grid-template-columns: 1fr 300px; }
  }

  .local-sidebar { display: flex; flex-direction: column; gap: 1rem; }

  .local-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 760px;
    margin-top: 1.5rem;
  }
</style>

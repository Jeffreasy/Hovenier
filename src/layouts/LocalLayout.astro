---
import BaseLayout from './BaseLayout.astro'
import Accordion from '../components/ui/Accordion.astro'
import type { SEOMeta, FAQItem, Stad } from '../lib/types'

interface Props {
  seo: SEOMeta
  stad: Stad
  aantalHoveniers?: number
  gemiddeldePrijs?: string
  faqs?: FAQItem[]
}

const {
  seo,
  stad,
  aantalHoveniers = 12,
  gemiddeldePrijs = '€45 – €75 per uur',
  faqs = [],
} = Astro.props

// LocalBusiness schema (platform)
const localSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `Tuinplatform – Hoveniers in ${stad.naam}`,
  description: seo.description,
  areaServed: {
    '@type': 'City',
    name: stad.naam,
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: stad.provincie,
    },
  },
  url: `https://www.tuinplatform.nl/steden/${stad.slug}`,
})

// FAQ schema
const faqSchema = faqs.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
}) : undefined

const combinedSchema = [localSchema, faqSchema].filter(Boolean).join('\n')
---

<BaseLayout seo={seo} schema={combinedSchema}>
  <div class="local-layout">
    <!-- Hero -->
    <header class="local-hero">
      <div class="container">
        <div class="local-breadcrumb">
          <a href="/">Home</a> / <a href="/steden">Steden</a> / <span>{stad.naam}</span>
        </div>

        <h1 class="local-title">
          Hovenier in {stad.naam}
          <span class="local-title-sub">Vergelijk en vind de beste</span>
        </h1>

        <div class="local-stats">
          <div class="local-stat">
            <strong>{aantalHoveniers}+</strong>
            <span>hoveniers actief</span>
          </div>
          <div class="local-stat">
            <strong>{gemiddeldePrijs}</strong>
            <span>gemiddeld tarief</span>
          </div>
          <div class="local-stat">
            <strong>Gratis</strong>
            <span>offertes vergelijken</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Inline offerte formulier -->
    <section class="local-offerte section-gap">
      <div class="container">
        <div class="local-offerte-card">
          <h2>Vraag gratis offertes aan in {stad.naam}</h2>
          <p>Ontvang binnen 48 uur maximaal 3 offertes van hoveniers bij jou in de buurt.</p>
          <slot name="offerte-form" />
        </div>
      </div>
    </section>

    <!-- Dynamische lokale content -->
    <section class="local-content section-gap">
      <div class="container local-content-grid">
        <div class="prose">
          <slot name="content" />
        </div>

        <aside class="local-sidebar">
          <slot name="sidebar" />
        </aside>
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && (
      <section class="local-faq section-gap">
        <div class="container">
          <h2>Veelgestelde vragen over hoveniers in {stad.naam}</h2>
          <div class="local-faq-list">
            {faqs.map((faq) => (
              <Accordion question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .local-hero {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    color: white;
    padding: 3rem 0;
  }

  .local-breadcrumb {
    font-size: 0.875rem;
    color: var(--color-primary-light);
    margin-bottom: 1.5rem;
  }

  .local-breadcrumb a {
    color: var(--color-primary-light);
    font-weight: 500;
  }

  .local-breadcrumb a:hover { color: white; }

  .local-title {
    color: white;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }

  .local-title-sub {
    font-size: 1.125rem;
    font-weight: 400;
    opacity: 0.85;
  }

  .local-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .local-stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .local-stat strong {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .local-stat span {
    font-size: 0.8rem;
    opacity: 0.8;
  }

  .local-offerte-card {
    background: white;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 2rem;
    max-width: 680px;
  }

  .local-offerte-card h2 { margin-top: 0; }

  .local-content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .local-content-grid {
      grid-template-columns: 1fr 300px;
    }
  }

  .local-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .local-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 760px;
    margin-top: 1.5rem;
  }
</style>

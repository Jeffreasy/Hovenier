---
import BaseLayout from './BaseLayout.astro'
import CTABlock from '../components/ui/CTABlock.astro'
import Accordion from '../components/ui/Accordion.astro'
import type { SEOMeta, FAQItem } from '../lib/types'

interface Props {
  seo: SEOMeta
  title: string
  intro: string
  faqs?: FAQItem[]
}

const { seo, title, intro, faqs = [] } = Astro.props

const faqSchema = faqs.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
}) : undefined
---

<BaseLayout seo={seo} schema={faqSchema}>
  <div class="tool-layout">
    <!-- Tool Header -->
    <header class="tool-header">
      <div class="container">
        <h1 class="tool-title">{title}</h1>
        <p class="tool-intro">{intro}</p>
      </div>
    </header>

    <!-- Interactive tool (React island) -->
    <section class="tool-island section-gap">
      <div class="container tool-island-inner">
        <slot name="tool" />
      </div>
    </section>

    <!-- Result CTA -->
    <slot name="result-cta" />

    <!-- SEO text -->
    <section class="tool-explainer section-gap">
      <div class="container prose">
        <slot name="explainer" />
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && (
      <section class="tool-faq section-gap">
        <div class="container">
          <h2>Veelgestelde vragen</h2>
          <div class="tool-faq-list">
            {faqs.map((faq) => (
              <Accordion question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <div class="container" style="padding-bottom: 4rem;">
      <CTABlock
        title="Klaar voor een echte offerte?"
        description="Op basis van jouw berekening kunnen we direct passende hoveniers voor je zoeken."
        href="/offerte"
        cta="Vraag gratis offertes aan"
        variant="banner"
      />
    </div>
  </div>
</BaseLayout>

<style>
  .tool-header {
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 3rem 0 2.5rem;
  }

  .tool-title { color: #EDF2EC; margin-bottom: 0.75rem; }

  .tool-intro {
    font-size: 1.125rem;
    color: rgba(237,242,236,0.60);
    max-width: 600px;
    margin: 0;
  }

  /* Island container: glass wrapper for React calculators */
  .tool-island-inner {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: var(--radius-xl);
    padding: 2rem;
    max-width: 760px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.30);
  }

  .tool-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 760px;
    margin-top: 1.5rem;
  }
</style>

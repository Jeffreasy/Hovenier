---
import BaseLayout from './BaseLayout.astro'
import CTABlock from '../components/ui/CTABlock.astro'
import Accordion from '../components/ui/Accordion.astro'
import type { SEOMeta, FAQItem } from '../lib/types'
import {
  faqSchema as buildFaqSchema,
  webApplicationSchema,
  breadcrumbSchema,
} from '../lib/seo'
import { SITE } from '../lib/constants'

interface Props {
  seo: SEOMeta
  title: string
  intro: string
  faqs?: FAQItem[]
  /** Slug onder /tools/, bijv. "tuinkosten-calculator". Activeert WebApplication + BreadcrumbList. */
  toolSlug?: string
  /** Override schema.org applicationCategory; default "FinanceApplication". */
  applicationCategory?: string
}

const {
  seo,
  title,
  intro,
  faqs = [],
  toolSlug,
  applicationCategory,
} = Astro.props

const toolUrl = toolSlug ? `${SITE.url}/tools/${toolSlug}` : undefined

const faqJsonLd = faqs.length > 0
  ? buildFaqSchema(faqs.map((f) => ({ question: f.question, answer: f.answer })))
  : undefined

const webAppJsonLd = toolUrl
  ? webApplicationSchema({ name: title, description: intro, url: toolUrl, applicationCategory })
  : undefined

const breadcrumbJsonLd = toolSlug ? breadcrumbSchema([
  { name: 'Home',  href: '/' },
  { name: 'Tools', href: '/tools/tuinkosten-calculator' },
  { name: title,   href: `/tools/${toolSlug}` },
]) : undefined

const combinedSchema = [webAppJsonLd, faqJsonLd, breadcrumbJsonLd]
  .filter(Boolean)
  .join('\n')
---

<BaseLayout seo={seo} schema={combinedSchema || undefined}>
  <div class="tool-layout">
    <!-- Tool Header -->
    <header class="tool-header">
      <div class="container">
        <h1 class="tool-title">{title}</h1>
        <p class="tool-intro">{intro}</p>
      </div>
    </header>

    <!-- Interactive tool (React island) -->
    <section class="tool-island section-gap">
      <div class="container tool-island-inner">
        <slot name="tool" />
      </div>
    </section>

    <!-- Result CTA -->
    <slot name="result-cta" />

    <!-- SEO text -->
    <section class="tool-explainer section-gap">
      <div class="container prose">
        <slot name="explainer" />
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && (
      <section class="tool-faq section-gap">
        <div class="container">
          <h2>Veelgestelde vragen</h2>
          <div class="tool-faq-list">
            {faqs.map((faq) => (
              <Accordion question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <div class="container" style="padding-bottom: 4rem;">
      <CTABlock
        title="Klaar voor een echte offerte?"
        description="Op basis van jouw berekening kunnen we direct passende hoveniers voor je zoeken."
        href="/offerte"
        cta="Vraag gratis offertes aan"
        variant="banner"
      />
    </div>
  </div>
</BaseLayout>

<style>
  .tool-header {
    background: var(--color-canvas-alt);
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0 2.5rem;
  }

  .tool-title { color: var(--color-charcoal); margin-bottom: 0.75rem; }

  .tool-intro {
    font-size: 1.125rem;
    color: var(--color-charcoal-light);
    max-width: 600px;
    margin: 0;
  }

  /* Clean card wrapper for React calculators */
  .tool-island-inner {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    padding: 2rem;
    max-width: 760px;
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .tool-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 760px;
    margin-top: 1.5rem;
  }
</style>

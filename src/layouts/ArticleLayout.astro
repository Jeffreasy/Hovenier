---
import BaseLayout from './BaseLayout.astro'
import CTABlock from '../components/ui/CTABlock.astro'
import type { SEOMeta } from '../lib/types'
import { formatDate } from '../lib/utils'

interface Props {
  seo: SEOMeta
  title: string
  description: string
  publishDate: Date
  updatedDate?: Date
  category: string
  readingTime?: number
  image?: string
  imageAlt?: string
  relatedPosts?: { title: string; href: string; category: string }[]
}

const {
  seo,
  title,
  description,
  publishDate,
  updatedDate,
  category,
  image,
  imageAlt = title,
  relatedPosts = [],
} = Astro.props

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: image ? [image] : undefined,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: 'TuinHub',
    url: 'https://www.tuinhub.nl',
  },
  publisher: {
    '@type': 'Organization',
    name: 'TuinHub',
    url: 'https://www.tuinhub.nl',
  },
})
---

<BaseLayout seo={{ ...seo, ogType: 'article', ogImage: image }} schema={articleSchema}>
  <article class="article-layout">
    <!-- Article header -->
    <header class="article-header">
      <div class="container">
        <div class="article-meta">
          <span class="article-category">{category}</span>
          <span class="article-reading-time">
            <slot name="reading-time" />
          </span>
        </div>

        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>

        <div class="article-byline">
          <span>TuinHub Redactie</span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={publishDate.toISOString()}>
            {formatDate(publishDate)}
          </time>
          {updatedDate && (
            <span class="article-updated">
              Bijgewerkt op <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
            </span>
          )}
        </div>
      </div>
    </header>

    <!-- Featured image -->
    {image && (
      <div class="article-image">
        <img src={image} alt={imageAlt} width="1200" height="630" loading="eager" />
      </div>
    )}

    <!-- Content + sidebar -->
    <div class="article-body container">
      <aside class="article-toc">
        <div class="toc-sticky">
          <slot name="toc" />
        </div>
      </aside>

      <div class="article-content prose">
        <slot />
        <CTABlock
          title="Wil je weten wat jouw tuin kost?"
          description="Gebruik onze gratis calculator voor een directe prijsindicatie."
          href="/tools/tuinkosten-calculator"
          cta="Bereken je tuinkosten"
          variant="inline"
        />
      </div>
    </div>

    <!-- Auteur-blok -->
    <div class="article-author container">
      <div class="author-block">
        <div class="author-avatar" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-7.5 8-13-2 1-3.5 1-5.5 0C10 8.5 8 11 7 14c-1.5 3-2 5-2 6"/><path d="M12 20c-2-2.5-3-5-3-8 2 .5 3.5 1 5 .5"/></svg>
        </div>
        <div class="author-info">
          <strong>TuinHub Redactie</strong>
          <p>Onze redactie bestaat uit tuinexperts en hoveniers die praktische adviezen schrijven voor Nederlandse tuineigenaren.</p>
        </div>
      </div>
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section class="article-related container">
        <h2>Gerelateerde artikelen</h2>
        <div class="related-grid">
          {relatedPosts.map((post) => (
            <a href={post.href} class="related-card">
              <span class="related-category">{post.category}</span>
              <span class="related-title">{post.title}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <div class="container" style="padding-bottom: 4rem;">
      <CTABlock
        title="Vraag gratis offertes aan"
        description="Vergelijk hoveniers in jouw buurt en vind de beste prijs."
        href="/offerte"
        cta="Vergelijk hoveniers"
        variant="banner"
      />
    </div>
  </article>
</BaseLayout>

<style>
  .article-header {
    background: var(--color-canvas-alt);
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .article-category {
    background: var(--color-primary-50);
    color: var(--color-primary-700);
    border: 1px solid var(--color-primary-200);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .article-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
    color: var(--color-charcoal);
  }

  .article-description {
    font-size: 1.125rem;
    color: var(--color-charcoal-light);
    max-width: 640px;
    margin-bottom: 1.5rem;
  }

  .article-byline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-charcoal-muted);
  }

  .article-image img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
  }

  .article-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: 3rem;
  }

  @media (min-width: 1024px) {
    .article-body { grid-template-columns: 240px 1fr; }
  }

  .article-toc { display: none; }

  @media (min-width: 1024px) {
    .article-toc { display: block; }
    .toc-sticky { position: sticky; top: 6rem; }
  }

  .article-author {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .author-block {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .author-avatar { color: var(--color-primary-500); flex-shrink: 0; }

  .author-info strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1rem;
    margin-bottom: 0.25rem;
    color: var(--color-charcoal);
  }

  .author-info p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-charcoal-light);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .related-card:hover {
    border-color: var(--color-primary-300);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .related-category {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-primary-500);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .related-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-charcoal);
  }
</style>

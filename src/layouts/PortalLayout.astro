<meta name="user-id" content={user?.id} />
<meta name="user-email" content={user?.email} />
<meta name="user-name" content={user?.name ?? 'Nieuwe Hovenier'} />

<script>
  import { ConvexHttpClient } from "convex/browser"
  import { api } from "../../convex/_generated/api.js"

  const userId = document.querySelector('meta[name="user-id"]')?.getAttribute('content') as string
  const convexUrl = import.meta.env.PUBLIC_CONVEX_URL as string
  
  if (userId && convexUrl) {
    const client = new ConvexHttpClient(convexUrl)

    async function loadCredits() {
      try {
        let data = await client.query(api.hoveniers.getMe, { userId })
        
        // Auto-provision profile if it does not exist yet!
        if (!data) {
          const userEmail = document.querySelector('meta[name="user-email"]')?.getAttribute('content') as string
          const userName = document.querySelector('meta[name="user-name"]')?.getAttribute('content') as string
          
          await client.mutation(api.hoveniers.upsertHovenier, { 
            userId, 
            email: userEmail, 
            naam: userName, 
            regio: [], 
            specialisaties: [] 
          })
          data = await client.query(api.hoveniers.getMe, { userId })
        }

        const el = document.getElementById('nav-credit-count')
        if (el) {
          el.textContent = String(data?.credits ?? 0)
        }
      } catch (err) {
        console.error('Failed to load credits', err)
      }
    }
    
    loadCredits()

    // Luister naar custom events om live header up te daten (bijv. na claimen)
    window.addEventListener('credits-updated', loadCredits)

    // ── Credit Shop Modal ──────────────────────────────────────────────────────

    let selectedAmount: number | null = null

    ;(window as any).openCreditShop = function() {
      const overlay = document.getElementById('credit-shop-overlay')
      if (!overlay) return
      const navCount = document.getElementById('nav-credit-count')?.textContent
      const modalCount = document.getElementById('cs-balance-count')
      if (modalCount && navCount) modalCount.textContent = navCount
      overlay.classList.add('cs-open')
      overlay.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    ;(window as any).closeCreditShop = function() {
      const overlay = document.getElementById('credit-shop-overlay')
      if (!overlay) return
      overlay.classList.remove('cs-open')
      overlay.setAttribute('aria-hidden', 'true')
      document.body.style.overflow = ''
    }

    ;(window as any).selectPackage = function(el: HTMLElement) {
      document.querySelectorAll('.cs-package').forEach(p => p.classList.remove('cs-selected'))
      el.classList.add('cs-selected')
      selectedAmount = parseInt(el.dataset.amount || '0', 10)
      const btn = document.getElementById('cs-buy-btn') as HTMLButtonElement
      if (btn && selectedAmount) {
        const names: Record<number, string> = { 5: 'Starter (5 credits)', 15: 'Groei (15 credits)', 35: 'Pro (35 credits)' }
        btn.textContent = 'Koop ' + (names[selectedAmount] || selectedAmount + ' credits')
        btn.disabled = false
      }
    }

    ;(window as any).purchaseSelected = async function() {
      if (!selectedAmount) return
      const btn = document.getElementById('cs-buy-btn') as HTMLButtonElement
      if (btn) { btn.classList.add('cs-loading'); btn.disabled = true; btn.textContent = 'Bezig...' }
      try {
        await client.mutation(api.hoveniers.addMockCreditsByUserId, { userId, amount: selectedAmount })
        await loadCredits()
        const navCount = document.getElementById('nav-credit-count')?.textContent
        const modalCount = document.getElementById('cs-balance-count')
        if (modalCount && navCount) modalCount.textContent = navCount
        ;(window as any).closeCreditShop()
        window.dispatchEvent(new Event('credits-updated'))
        selectedAmount = null
        document.querySelectorAll('.cs-package').forEach(p => p.classList.remove('cs-selected'))
        if (btn) { btn.textContent = 'Pakket selecteren...'; btn.disabled = true; btn.classList.remove('cs-loading') }
      } catch (err: any) {
        if (btn) { btn.classList.remove('cs-loading'); btn.disabled = false; btn.textContent = 'Opnieuw proberen' }
        alert('Fout: ' + (err?.message || 'Kon credits niet bijschrijven'))
      }
    }

    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') (window as any).closeCreditShop() })
  }
</script>

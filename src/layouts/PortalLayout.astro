---
import { UserButton } from '@clerk/astro/components'

interface Props {
  title: string
  activeNav?: 'dashboard' | 'profiel' | 'admin'
  maxWidth?: string
  showBackLink?: boolean
}

const {
  title,
  activeNav,
  maxWidth = '1100px',
  showBackLink = false,
} = Astro.props
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  <title>{title} | Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      {showBackLink ? (
        <a href="/portal" class="portal-back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Terug naar dashboard
        </a>
      ) : (
        <>
          <a href="/" class="portal-logo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#008d51" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-7.5 8-13-2 1-3.5 1-5.5 0C10 8.5 8 11 7 14c-1.5 3-2 5-2 6"/><path d="M12 20c-2-2.5-3-5-3-8 2 .5 3.5 1 5 .5"/></svg>
            <span>TuinHub</span>
          </a>
          <nav class="portal-nav">
            <a href="/portal" class:list={["portal-nav-link", { "portal-nav-link--active": activeNav === 'dashboard' }]}>Dashboard</a>
            <a href="/portal/profiel" class:list={["portal-nav-link", { "portal-nav-link--active": activeNav === 'profiel' }]}>Mijn profiel</a>
            <a href="/portal/admin" class:list={["portal-nav-link", { "portal-nav-link--active": activeNav === 'admin' }]}>Admin</a>
          </nav>
        </>
      )}
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container" style={`max-width: ${maxWidth};`}>
      <slot />
    </div>
  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #f8fafc;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .portal-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #282d31;
    text-decoration: none;
    flex-shrink: 0;
  }

  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }

  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    transition: all 0.15s;
  }

  .portal-nav-link:hover { background: #f1f5f9; color: #282d31; }

  .portal-nav-link--active {
    background: rgba(0,141,81,0.08);
    color: #008d51;
    font-weight: 600;
  }

  .portal-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: #008d51;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .portal-back:hover { opacity: 0.75; text-decoration: none; }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { margin: 0 auto; }
</style>

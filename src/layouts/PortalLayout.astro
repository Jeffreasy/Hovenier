---
import '../styles/global.css'

const user = Astro.locals.user

interface Props {
  title: string
  activeNav?: 'dashboard' | 'profiel' | 'admin'
  maxWidth?: string
  showBackLink?: boolean
}

const {
  title,
  activeNav,
  maxWidth = '1100px',
  showBackLink = false,
} = Astro.props
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  
  <!-- Google Search Console -->
  <meta name="google-site-verification" content="JMKXT3Xnuzb8x8zRNO42Fw7Ylwku-aIbRQymlyMhMt0" />

  <title>{title} | Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      {showBackLink ? (
        <a href="/portal" class="portal-back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Terug naar dashboard
        </a>
      ) : (
        <>
          <a href="/" class="portal-logo" aria-label="TuinHub homepage">
            <svg class="portal-logo-icon" viewBox="0 0 1024 1024" aria-hidden="true">
              <g fill="#282d31">
                <circle cx="512.5" cy="162.4" r="26.7"/><circle cx="863.1" cy="512.2" r="26.7"/><circle cx="160.8" cy="512.2" r="26.7"/><circle cx="512.7" cy="862.4" r="26.7"/><circle cx="761.3" cy="263.3" r="26.7"/><circle cx="263.1" cy="761.1" r="26.7"/><circle cx="262.9" cy="263" r="26.7"/><circle cx="761.1" cy="761.3" r="26.7"/>
                <path d="M295.28 781.24l6.31-8.01c.85.26 29.18 20.76 32.37 22.84 36.95 24.11 78.4 40.48 121.85 48.13 7.28 1.29 16.19 2.85 23.52 3.39.07 3.07.58 7.05-.42 9.7-1.55 1.07-1.32.67-3.74.49-8.24-.72-18.53-2.63-26.66-4.19C401.12 845.03 356.27 826.07 316.97 798.27c-6.9-4.88-15.56-11.09-21.75-16.78l.06-.25Z"/>
                <path d="M472.01 157.71l.76.37c.44 2.16.25 7.82.23 10.31-10.55.84-22.36 3.3-32.78 5.45-50.02 10.32-105.85 35.03-143.99 69.42l-3.37-3.36-4.32-4.14c5.48-6.26 18.26-14.76 25.32-19.67 50.11-34.85 98.47-50.03 158.15-58.38Z"/>
                <path d="M551.59 157.88c9.77.51 27.54 3.89 37.08 5.92 43.72 9.3 83.19 26.13 120.21 51.13 8.04 5.43 20.57 13.94 27.13 20.97l-3.03 3.42c-1.07 1.33-2.37 2.69-3.53 3.97C683.77 206.43 627.79 180.26 569.67 170.99c-6.04-.97-12.14-1.79-18.21-2.62l.13-10.49Z"/>
                <path d="M235.87 289.86c2.83 2.72 4.33 4.15 7.48 6.41-8.26 10.64-15.97 20.58-23.44 31.94-21.66 33.26-37.26 70.1-46.05 108.81-1.78 7.78-3.25 15.63-4.41 23.53-.57 4.14-.74 9.22-1.6 13.13l-1.22.29-7.71.04c.2-7.31 1.83-18.44 2.99-25.7 8.79-55.15 37.29-117.15 74.97-158.45Z"/>
                <path d="M728.53 781.87l.69.06c1.46 1.03 4.78 5.68 6.03 7.33-8.01 7.59-20.09 15.8-29.27 21.86-44.22 29.53-94.79 48.19-147.59 54.47-2.13.35-4.79.59-6.98.85l-.06-10.77c55.48-5.49 108.95-26.33 155.06-57.33 7.46-5.02 14.81-11.09 22.12-16.47Z"/>
                <path d="M856.63 550.39l10.1.04c-.6 13.84-3.44 28.34-6.56 41.8-11.55 52.06-35.75 100.47-70.45 140.95l-.88.95c-2.27-.05-6.07-4.27-7.9-6l.05-.02c33.69-40.3 57.39-88.07 69.08-139.35 2.48-10.6 5.76-27.6 6.55-38.37Z"/>
                <path d="M157.63 550.55l10.24.06c8.78 67.1 32 125.19 75.78 177.5-1.17.87-2.11 1.74-3.21 2.69l-4.22 4.18c-7.31-7.99-15.97-19.8-22.05-28.73-31.62-46.33-51.06-99.88-56.54-155.7Z"/>
                <path d="M788.94 290c6.94 7.56 14.86 18.4 20.68 26.78 32.32 46.73 52.13 100.97 57.53 157.53-2.36-.02-4.9-.17-7.28-.25-1.05 0-2.64.18-2.82-.95-2.47-17.38-5.38-34.47-10-51.42-12.9-47.37-35.62-87.02-65.73-125.38l7.61-6.16-.01-.15Z"/>
              </g>
              <path fill="#1E904A" d="M678.62 275.97c.81.56 1.63 1.11 2.45 1.66 9.48 88.55 11.17 178.29-27.72 260.81-31.59 67.04-88.94 123.9-165.47 132.09-24.9 2.74-50.09.2-73.95-7.42 8.55-23.19 22.66-41.21 45.44-51.76 12.45-5.77 26.67-8.46 40.35-7.95 16.4.6 30.72-1.87 46.42-6.42l-1.2-1.62c-13.36 1.41-28.69.71-42.01-1.21-97.5-14.04-123.03 90.09-122.35 167.83l-29.71-.13c.85-29.28 13.19-73.01 24.67-99.57 15.27-35.3 37.6-72.41 63.59-100.95 5.47-6.01 12.26-13.36 19-17.63 17.58-11.43 38.77-18.49 60.07-16.13 28.85 3.2 53.72 7.26 82.22-4.1l-.35-1.17c-16.02 2.7-35.84 1.38-51.93-1.45-24.63-4.33-38.91-9.89-64.24-4.63 22.68-22.1 52.55-46.38 77.81-65.88 25.17 5.73 58 1.42 81.53-8.57l-.43-.96c-23.1 5.53-48.1 4.07-71.55 2.03 39.15-32.86 65.18-59.89 87.9-105.6l-.6-1.15c-30.36 57.05-79.75 88.24-131.1 124.61.01-34.13 10.8-55.75 34.54-79.61l.37-.37-1-.85c-27.05 24.23-46.75 49.48-48.9 87.7-.09 1.83-.13 3.66-.13 5.49-24.96 18.83-48.12 37.95-68.79 61.49-2.16 2.46-4.61 5.14-6.87 7.49-5.08-35.09-1.56-54.88 17.89-85.44l-.7-1.03c-29.24 31.37-36.55 58.36-31.18 100.34-14.31 15.95-27.31 30.88-39.16 48.89-5.67 8.61-10.73 17.75-15.8 26.73-23.59-37.95-24.57-94.58-9-135.78 2.42-6.4 5.21-13.01 8.22-19.16 11.05-22.57 25.99-43 44.17-60.36 39.04-37.67 79.67-54.35 131.29-68.82 24.07-6.74 47.97-9.9 71.45-18.35 31.13-11.21 50.09-22.97 64.75-53.06Z"/>
            </svg>
            <span class="portal-logo-text">Tuin<span class="portal-logo-accent">Hub</span></span>
          </a>
          <nav class="portal-nav">
            <a href="/portal" class:list={["portal-nav-link", { "portal-nav-link--active": activeNav === 'dashboard' }]}>Dashboard</a>
            <a href="/portal/profiel" class:list={["portal-nav-link", { "portal-nav-link--active": activeNav === 'profiel' }]}>Mijn profiel</a>
            <a href="/portal/admin" class:list={["portal-nav-link", { "portal-nav-link--active": activeNav === 'admin' }]}>Admin</a>
          </nav>
        </>
      )}
      <div class="portal-user">
        {user && (
          <div class="user-menu">
            
            <div class="credit-badge" title="Jouw Lead-Krediet saldo" id="credit-badge-btn" onclick="window.openCreditShop()" style="cursor:pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="credit-icon"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
              <span class="credit-count" id="nav-credit-count">--</span>
              <span class="credit-add" title="Credits kopen">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </span>
            </div>

            <span class="user-email">{user.name || user.email}</span>
            <button class="logout-btn" id="logoutBtn">Uitloggen</button>
          </div>
        )}
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container" style={`max-width: ${maxWidth};`}>
      <slot />
    </div>
  </main>

</body>
</html>

<!-- ── Credit Shop Modal ────────────────────────────────────── -->
<div id="credit-shop-overlay" class="cs-overlay" onclick="if(event.target===this)window.closeCreditShop()" aria-hidden="true">
  <div class="cs-drawer" role="dialog" aria-modal="true" aria-label="Credits kopen">

    <div class="cs-header">
      <div>
        <h2 class="cs-title">Credits kopen</h2>
        <p class="cs-subtitle">Kies een pakket en bekijk direct leads van klanten in jouw regio.</p>
      </div>
      <button class="cs-close" onclick="window.closeCreditShop()" aria-label="Sluiten">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <div class="cs-balance">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
      <span>Huidig saldo: <strong id="cs-balance-count">--</strong> credits</span>
    </div>

    <div class="cs-packages">

      <div class="cs-package" data-amount="5" onclick="window.selectPackage(this)">
        <div class="cs-pkg-top">
          <div class="cs-pkg-name">Starter</div>
          <div class="cs-pkg-credits">5 <span>credits</span></div>
        </div>
        <div class="cs-pkg-price">€ 19,95</div>
        <div class="cs-pkg-desc">Ideaal om het platform te verkennen. Bekijk 5 aanvragen in jouw regio.</div>
        <div class="cs-pkg-per">€ 3,99 per lead</div>
      </div>

      <div class="cs-package cs-package--popular" data-amount="15" onclick="window.selectPackage(this)">
        <div class="cs-pkg-badge">Meest gekozen</div>
        <div class="cs-pkg-top">
          <div class="cs-pkg-name">Groei</div>
          <div class="cs-pkg-credits">15 <span>credits</span></div>
        </div>
        <div class="cs-pkg-price">€ 49,95 <s class="cs-pkg-old">€ 59,85</s></div>
        <div class="cs-pkg-desc">Perfect voor actieve hoveniers. Bespaar 17% ten opzichte van Starter.</div>
        <div class="cs-pkg-per">€ 3,33 per lead</div>
      </div>

      <div class="cs-package" data-amount="35" onclick="window.selectPackage(this)">
        <div class="cs-pkg-top">
          <div class="cs-pkg-name">Pro</div>
          <div class="cs-pkg-credits">35 <span>credits</span></div>
        </div>
        <div class="cs-pkg-price">€ 99,95 <s class="cs-pkg-old">€ 139,65</s></div>
        <div class="cs-pkg-desc">Voor de serieuze professional. Maximale besparing, minimale prijs per lead.</div>
        <div class="cs-pkg-per">€ 2,86 per lead</div>
      </div>

    </div>

    <div class="cs-footer">
      <p class="cs-note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Test modus — credits worden direct bijgeschreven zonder betaling.
      </p>
      <button id="cs-buy-btn" class="cs-buy-btn" onclick="window.purchaseSelected()" disabled>
        Pakket selecteren...
      </button>
    </div>

  </div>
</div>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #f8fafc;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .portal-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .portal-logo:hover { text-decoration: none; }

  .portal-logo-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .portal-logo-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    color: #282d31;
    letter-spacing: -0.025em;
    line-height: 1;
  }

  .portal-logo-accent {
    color: #008d51;
  }

  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }

  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    transition: all 0.15s;
  }

  .portal-nav-link:hover { background: #f1f5f9; color: #282d31; }

  .portal-nav-link--active {
    background: rgba(0,141,81,0.08);
    color: #008d51;
    font-weight: 600;
  }

  .portal-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: #008d51;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .portal-back:hover { opacity: 0.75; text-decoration: none; }

  .portal-user { margin-left: auto; }

  .user-menu {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .user-email {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #475569;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .logout-btn {
    padding: 0.375rem 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Inter', sans-serif;
  }

  .logout-btn:hover {
    border-color: var(--color-error);
    color: var(--color-error);
    background: var(--color-error-light);
  }

  /* ── Credit Badge ── */
  .credit-badge {
    display: inline-flex;
    align-items: center;
    background: var(--color-canvas-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.25rem 0.375rem 0.25rem 0.75rem;
    gap: 0.5rem;
  }

  .credit-icon {
    color: var(--color-warning);
    fill: var(--color-warning-light);
  }

  .credit-count {
    font-size: 0.875rem;
    font-weight: 700;
    font-family: var(--font-heading);
    color: var(--color-charcoal);
  }

  .credit-add {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-primary-500);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1;
    text-decoration: none;
    transition: all 0.15s;
    margin-left: 0.25rem;
  }

  .credit-add:hover {
    background: var(--color-primary-50);
    border-color: var(--color-primary-200);
    color: var(--color-primary-600);
    text-decoration: none;
    transform: scale(1.05);
  }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { margin: 0 auto; }

  /* ── Credit Shop Modal ── */
  .cs-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.45);
    backdrop-filter: blur(4px);
    z-index: 200;
    display: flex;
    justify-content: flex-end;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .cs-overlay.cs-open {
    opacity: 1;
    pointer-events: all;
  }

  .cs-drawer {
    width: 100%;
    max-width: 480px;
    height: 100%;
    background: #ffffff;
    box-shadow: -4px 0 40px rgba(0,0,0,0.12);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
  }

  .cs-overlay.cs-open .cs-drawer {
    transform: translateX(0);
  }

  .cs-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.75rem 1.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    gap: 1rem;
  }

  .cs-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
  }

  .cs-subtitle {
    font-size: 0.8125rem;
    color: #64748b;
    margin-top: 0.25rem;
    line-height: 1.5;
  }

  .cs-close {
    background: #f1f5f9;
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #64748b;
    transition: all 0.15s;
  }

  .cs-close:hover { background: #e2e8f0; color: #0f172a; }

  .cs-balance {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 1.75rem;
    padding: 0.75rem 1rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    font-size: 0.875rem;
    color: #166534;
  }

  .cs-balance strong { font-weight: 700; }

  .cs-packages {
    padding: 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .cs-package {
    position: relative;
    border: 2px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.125rem 1.25rem;
    cursor: pointer;
    transition: all 0.18s ease;
    background: #ffffff;
    overflow: hidden;
  }

  .cs-package:hover {
    border-color: #86efad;
    background: #f0fdf4;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,141,81,0.08);
  }

  .cs-package.cs-selected {
    border-color: #008d51;
    background: #f0fdf4;
    box-shadow: 0 0 0 3px rgba(0,141,81,0.12);
  }

  .cs-package--popular {
    border-color: #008d51;
  }

  .cs-pkg-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #008d51;
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 0 12px 0 10px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .cs-pkg-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.375rem;
  }

  .cs-pkg-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
  }

  .cs-pkg-credits {
    font-size: 1.5rem;
    font-weight: 800;
    color: #008d51;
    font-family: 'Plus Jakarta Sans', sans-serif;
    line-height: 1;
  }

  .cs-pkg-credits span {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    display: block;
    text-align: right;
    margin-top: 2px;
  }

  .cs-pkg-price {
    font-size: 1.125rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.375rem;
  }

  .cs-pkg-old {
    font-size: 0.875rem;
    color: #94a3b8;
    font-weight: 400;
    margin-left: 0.25rem;
  }

  .cs-pkg-desc {
    font-size: 0.8125rem;
    color: #475569;
    line-height: 1.5;
    margin-bottom: 0.25rem;
  }

  .cs-pkg-per {
    font-size: 0.75rem;
    color: #008d51;
    font-weight: 600;
  }

  .cs-footer {
    padding: 1.25rem 1.75rem 1.75rem;
    border-top: 1px solid #f1f5f9;
    margin-top: auto;
  }


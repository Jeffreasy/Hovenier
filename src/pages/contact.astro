---
import BaseLayout from '../layouts/BaseLayout.astro'
import Button from '../components/ui/Button.astro'
import { SITE } from '../lib/constants'

const seo = {
  title: 'Contact — Tuinplatform',
  description: 'Neem contact op met Tuinplatform. Heb je een vraag over onze diensten of wil je meer weten over hoe ons platform werkt?',
}
---

<BaseLayout {seo}>
  <div class="contact-page section-gap">
    <div class="container contact-inner">
      <header class="contact-header reveal">
        <p class="section-label">Contact</p>
        <h1>Heb je een vraag?</h1>
        <p class="contact-sub">Stuur ons een bericht en we reageren binnen 1 werkdag.</p>
      </header>

      <div class="contact-grid">
        <form class="contact-form reveal" action="#" method="post">
          <div class="form-field">
            <label for="naam">Jouw naam</label>
            <input id="naam" name="naam" type="text" placeholder="Jan de Vries" required />
          </div>
          <div class="form-field">
            <label for="email">E-mailadres</label>
            <input id="email" name="email" type="email" placeholder="jan@voorbeeld.nl" required />
          </div>
          <div class="form-field">
            <label for="onderwerp">Onderwerp</label>
            <input id="onderwerp" name="onderwerp" type="text" placeholder="Vraag over..." required />
          </div>
          <div class="form-field">
            <label for="bericht">Bericht</label>
            <textarea id="bericht" name="bericht" rows={5} placeholder="Jouw bericht..." required></textarea>
          </div>
          <Button type="submit" size="lg">Verstuur bericht</Button>
        </form>

        <aside class="contact-info reveal delay-200">
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">📧</span>
            <div>
              <strong>E-mail</strong>
              <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
            </div>
          </div>
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">⏱</span>
            <div>
              <strong>Reactietijd</strong>
              <p>Binnen 1 werkdag</p>
            </div>
          </div>
          <div class="info-note">
            <strong>Ben je hovenier?</strong>
            <p>Wil je als hovenier leads ontvangen via ons platform? Stuur een e-mail met "Hovenier aanmelding" als onderwerp.</p>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-inner { max-width: 900px; }

  .contact-header { margin-bottom: 2.5rem; }

  .contact-sub {
    font-size: 1.125rem;
    color: rgba(237,242,236,0.58);
    margin: 0.25rem 0 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .contact-grid { grid-template-columns: 1fr 300px; }
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-field { display: flex; flex-direction: column; gap: 0.375rem; }

  .form-field label {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(237,242,236,0.60);
    letter-spacing: 0.02em;
  }

  .form-field input,
  .form-field textarea {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1rem;
    color: #EDF2EC;
    background: rgba(255,255,255,0.06);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    resize: vertical;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: rgba(237,242,236,0.25);
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: rgba(196,169,106,0.40);
    background: rgba(255,255,255,0.09);
  }

  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }

  .info-block { display: flex; gap: 0.875rem; align-items: flex-start; }
  .info-icon { font-size: 1.5rem; flex-shrink: 0; }
  .info-block strong {
    display: block;
    font-family: var(--font-heading);
    color: rgba(237,242,236,0.85);
    margin-bottom: 0.125rem;
  }
  .info-block a,
  .info-block p {
    margin: 0;
    font-size: 0.9375rem;
    color: rgba(237,242,236,0.50);
  }

  .info-note {
    background: rgba(110,158,101,0.10);
    border: 1px solid rgba(110,158,101,0.22);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-md);
    padding: 1rem;
  }

  .info-note strong {
    display: block;
    font-family: var(--font-heading);
    color: rgba(237,242,236,0.85);
    margin-bottom: 0.375rem;
  }

  .info-note p {
    margin: 0;
    font-size: 0.875rem;
    color: rgba(237,242,236,0.52);
    line-height: 1.65;
  }
</style>

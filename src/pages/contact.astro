---
import BaseLayout from '../layouts/BaseLayout.astro'
import Button from '../components/ui/Button.astro'
import { SITE } from '../lib/constants'

const seo = {
  title: 'Contact',
  description: 'Neem contact op met TuinHub. Heb je een vraag over onze diensten of wil je meer weten over hoe ons platform werkt?',
}
---

<BaseLayout {seo}>
  <div class="contact-page section-gap">
    <div class="container contact-inner">
      <header class="contact-header reveal">
        <p class="section-label">Contact</p>
        <h1>Heb je een vraag?</h1>
        <p class="contact-sub">Stuur ons een bericht en we reageren binnen 1 werkdag.</p>
      </header>

      <div class="contact-grid">
        <form class="contact-form reveal" action="#" method="post">
          <div class="form-field">
            <label for="naam">Jouw naam</label>
            <input id="naam" name="naam" type="text" placeholder="Jan de Vries" required />
          </div>
          <div class="form-field">
            <label for="email">E-mailadres</label>
            <input id="email" name="email" type="email" placeholder="jan@voorbeeld.nl" required />
          </div>
          <div class="form-field">
            <label for="onderwerp">Onderwerp</label>
            <input id="onderwerp" name="onderwerp" type="text" placeholder="Vraag over..." required />
          </div>
          <div class="form-field">
            <label for="bericht">Bericht</label>
            <textarea id="bericht" name="bericht" rows={5} placeholder="Jouw bericht..." required></textarea>
          </div>
          <Button type="submit" size="lg">Verstuur bericht</Button>
        </form>

        <aside class="contact-info reveal delay-200">
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <div>
              <strong>E-mail</strong>
              <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
            </div>
          </div>
          <div class="info-block">
            <span class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <div>
              <strong>Reactietijd</strong>
              <p>Binnen 1 werkdag</p>
            </div>
          </div>
          <div class="info-note">
            <strong>Ben je hovenier?</strong>
            <p>Wil je als hovenier leads ontvangen via ons platform? Stuur een e-mail met "Hovenier aanmelding" als onderwerp.</p>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-inner { max-width: 900px; }

  .contact-header { margin-bottom: 2.5rem; }

  .contact-sub {
    font-size: 1.125rem;
    color: var(--color-charcoal-light);
    margin: 0.25rem 0 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .contact-grid { grid-template-columns: 1fr 300px; }
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-field { display: flex; flex-direction: column; gap: 0.375rem; }

  .form-field label {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-charcoal-light);
    letter-spacing: 0.02em;
  }

  .form-field input,
  .form-field textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-charcoal);
    background: var(--color-white);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    resize: vertical;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--color-charcoal-muted);
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
  }

  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }

  .info-block { display: flex; gap: 0.875rem; align-items: flex-start; }
  .info-icon { flex-shrink: 0; color: var(--color-primary-500); }
  .info-block strong {
    display: block;
    font-family: var(--font-heading);
    color: var(--color-charcoal);
    margin-bottom: 0.125rem;
  }
  .info-block a,
  .info-block p {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-charcoal-light);
  }
  .info-block a {
    color: var(--color-primary-600);
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .info-block a:hover { color: var(--color-primary-500); text-decoration: underline; }

  .info-note {
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-200);
    border-left: 3px solid var(--color-primary-500);
    border-radius: var(--radius-md);
    padding: 1rem;
  }

  .info-note strong {
    display: block;
    font-family: var(--font-heading);
    color: var(--color-charcoal);
    margin-bottom: 0.375rem;
  }

  .info-note p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-charcoal-light);
    line-height: 1.65;
  }
</style>

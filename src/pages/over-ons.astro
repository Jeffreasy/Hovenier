---
import BaseLayout from '../layouts/BaseLayout.astro'
import Button from '../components/ui/Button.astro'
import { SOCIAL_PROOF } from '../lib/constants'

const seo = {
  title: 'Over TuinHub — Hoe wij hoveniers en huiseigenaren koppelen',
  description: 'TuinHub koppelt huiseigenaren aan betrouwbare hoveniers. Ontdek hoe ons platform werkt en waarom ' + SOCIAL_PROOF.offertes + ' offertes zijn aangevraagd.',
}
---

<BaseLayout {seo}>
  <div class="about-page">
    <!-- Hero -->
    <header class="about-hero">
      <div class="container">
        <p class="section-label reveal">Over ons</p>
        <h1 class="reveal">Wij koppelen jou aan<br/> de beste hovenier in jouw buurt</h1>
        <p class="about-intro reveal delay-100">
          TuinHub is een onafhankelijk platform waarop huiseigenaren gratis offertes aanvragen
          bij lokale hoveniers. Transparant, snel en vrijblijvend.
        </p>
      </div>
    </header>

    <!-- Hoe het werkt -->
    <section class="section-gap">
      <div class="container">
        <p class="section-label reveal">Werkwijze</p>
        <h2 class="reveal">Hoe het werkt</h2>
        <div class="how-grid">
          {[
            { icon: '🔍', title: 'Jij stelt je vraag', desc: 'Vul in wat je wilt laten doen, wat je budget is en waar je woont.' },
            { icon: '🤝', title: 'Wij zoeken voor jou', desc: 'Ons platform matcht jouw aanvraag met beschikbare hoveniers in jouw regio.' },
            { icon: '📋', title: 'Jij vergelijkt', desc: 'Ontvang meerdere offertes en kies de hovenier die het beste bij jou past.' },
          ].map((step, i) => (
            <div class={`how-item reveal delay-${(i+1)*100}`}>
              <div class="how-icon" aria-hidden="true">{step.icon}</div>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="about-stats section-gap">
      <div class="container">
        <div class="stats-row">
          {[
            { val: SOCIAL_PROOF.offertes, label: 'Aangevraagde offertes' },
            { val: SOCIAL_PROOF.hoveniers, label: 'Aangesloten hoveniers' },
            { val: `${SOCIAL_PROOF.rating} / 5`, label: 'Gemiddelde beoordeling' },
          ].map((s) => (
            <div class="about-stat reveal">
              <strong>{s.val}</strong>
              <span>{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-gap">
      <div class="container" style="text-align: center;">
        <h2 class="reveal">Klaar om te starten?</h2>
        <p class="reveal delay-100" style="color: rgba(237,242,236,0.58); margin-bottom: 1.5rem;">Vraag gratis en vrijblijvend offertes aan bij hoveniers bij jou in de buurt.</p>
        <Button href="/offerte" size="lg">Vraag gratis offertes aan</Button>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about-hero {
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 4rem 0;
  }

  .about-hero h1 { max-width: 600px; color: #EDF2EC; }

  .about-intro {
    font-size: 1.125rem;
    color: rgba(237,242,236,0.55);
    max-width: 540px;
    margin: 1rem 0 0;
  }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .how-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .how-item {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .how-item:hover {
    border-color: rgba(196,169,106,0.22);
    transform: translateY(-2px);
  }

  .how-icon { font-size: 2rem; margin-bottom: 0.75rem; }
  .how-item h3 { margin-bottom: 0.5rem; color: #EDF2EC; }
  .how-item p { margin: 0; color: rgba(237,242,236,0.52); font-size: 0.9rem; }

  /* Stats dark section */
  .about-stats {
    background: rgba(8,18,10,0.60);
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .stats-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
  }

  .about-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .about-stat strong {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-secondary);
  }

  .about-stat span {
    font-size: 0.875rem;
    color: rgba(237,242,236,0.45);
  }
</style>

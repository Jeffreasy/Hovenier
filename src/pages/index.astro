---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/home/Hero.astro'
import TrustBadges from '../components/home/TrustBadges.astro'
import Button from '../components/ui/Button.astro'
import Card from '../components/ui/Card.astro'
import Badge from '../components/ui/Badge.astro'
import { SOCIAL_PROOF } from '../lib/constants'
import { getCollection } from 'astro:content'
import { formatDate } from '../lib/utils'
import { websiteSchema, organizationSchema } from '../lib/seo'

const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)

const seo = {
  title: 'Hovenier vinden en vergelijken | gratis offertes',
  description: 'Vind de beste hovenier in jouw buurt. Vergelijk tarieven, lees reviews en vraag gratis offertes aan. Nu al ' + SOCIAL_PROOF.offertes + ' offertes aangevraagd.',
}

// Combined JSON-LD: Organization (E-E-A-T baseline) + WebSite (with SearchAction).
// Voeg `sameAs` URLs toe zodra social profielen live zijn.
const homeSchema = [
  organizationSchema({ /* sameAs: ['https://www.linkedin.com/...', ...] */ }),
  websiteSchema(),
].join('\n')
---

<BaseLayout {seo} schema={homeSchema}>

  <!-- ════════════════════ HERO ════════════════════ -->
  <Hero />

  <!-- ════════════════════ TRUST BADGES ════════════════════ -->
  <TrustBadges />

  <!-- ════════════════════ STATS ════════════════════ -->
  <section class="section-gap" aria-label="Platform statistieken">
    <div class="container">
      <div class="stats-grid reveal-up">
        <div class="stat-item reveal-fade delay-100">
          <strong class="stat-number">{SOCIAL_PROOF.offertes}</strong>
          <span class="stat-label">Offertes aangevraagd</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item reveal-fade delay-200">
          <strong class="stat-number">{SOCIAL_PROOF.hoveniers}</strong>
          <span class="stat-label">Actieve hoveniers</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item reveal-fade delay-300">
          <strong class="stat-number">{SOCIAL_PROOF.rating}</strong>
          <span class="stat-label">Gemiddelde beoordeling</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item reveal-fade delay-400">
          <strong class="stat-number">{SOCIAL_PROOF.reviews}+</strong>
          <span class="stat-label">Beoordelingen</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════ HOE HET WERKT ════════════════════ -->
  <section class="section-alt section-gap" aria-label="Hoe het werkt">
    <div class="container">
      <p class="section-label reveal">Hoe het werkt</p>
      <h2 class="section-title reveal">In 3 stappen jouw hovenier gevonden</h2>
      <div class="steps-grid">
        {[
          {
            num: '1',
            title: 'Vul je wensen in',
            desc: 'Postcode, type werkzaamheid en jouw budget. In 2 minuten ingevuld.',
            icon: 'clipboard',
          },
          {
            num: '2',
            title: 'Ontvang offertes',
            desc: 'Binnen 48 uur maximaal 3 offertes van hoveniers bij jou in de buurt.',
            icon: 'mail',
          },
          {
            num: '3',
            title: 'Kies jouw hovenier',
            desc: 'Vergelijk op prijs en kwaliteit. Beslis zonder druk.',
            icon: 'check',
          },
        ].map((step, i) => (
          <div class={`step-card reveal-up delay-${(i+1)*100}`}>
            <div class="step-icon" aria-hidden="true">
              {step.icon === 'clipboard' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                  <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                  <path d="M9 14l2 2 4-4"/>
                </svg>
              )}
              {step.icon === 'mail' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              )}
              {step.icon === 'check' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
              )}
            </div>
            <div class="step-num" aria-hidden="true">{step.num}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════ CALCULATORS ════════════════════ -->
  <section class="section-gap" aria-label="Handige tools">
    <div class="container">
      <p class="section-label reveal">Gratis tools</p>
      <h2 class="section-title reveal">Bereken je kosten</h2>
      <p class="section-subtitle reveal">Gebruik onze gratis tools voor een directe prijsindicatie.</p>
      <div class="calc-grid">
        {[
          {
            title: 'Tuinkosten Calculator',
            desc: 'Bereken wat tuinaanleg, bestrating of beplanting jou kost op basis van m2 en kwaliteitsniveau.',
            href: '/tools/tuinkosten-calculator',
            cta: 'Bereken gratis',
            icon: 'ruler',
          },
          {
            title: 'Schutting Kosten Delen',
            desc: 'Bereken de schuttingkosten en deel de berekening direct via WhatsApp met je buurman.',
            href: '/tools/schutting-kosten-calculator',
            cta: 'Bekijk tool',
            icon: 'fence',
          },
          {
            title: 'Subsidie Check',
            desc: 'Voer je postcode in en ontdek welke groensubsidies beschikbaar zijn in jouw gemeente.',
            href: '/tools/subsidie-check',
            cta: 'Check subsidies',
            icon: 'coins',
          },
        ].map((calc, i) => (
          <Card href={calc.href} class={`calc-card reveal delay-${(i+1)*100}`}>
            <div class="calc-icon" aria-hidden="true">
              {calc.icon === 'ruler' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"/>
                  <path d="m14.5 12.5 2-2"/>
                  <path d="m11.5 9.5 2-2"/>
                  <path d="m8.5 6.5 2-2"/>
                  <path d="m17.5 15.5 2-2"/>
                </svg>
              )}
              {calc.icon === 'fence' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 3v18"/>
                  <path d="M12 3v18"/>
                  <path d="M20 3v18"/>
                  <path d="M2 9h20"/>
                  <path d="M2 15h20"/>
                </svg>
              )}
              {calc.icon === 'coins' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="8" cy="8" r="6"/>
                  <path d="M18.09 10.37A6 6 0 1 1 10.34 18"/>
                  <path d="M7 6h1v4"/>
                  <path d="m16.71 13.88.7.71-2.82 2.82"/>
                </svg>
              )}
            </div>
            <h3 class="calc-title">{calc.title}</h3>
            <p class="calc-desc">{calc.desc}</p>
            <span class="calc-link">
              {calc.cta}
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════ BLOG ════════════════════ -->
  {recentPosts.length > 0 && (
    <section class="section-gap" aria-label="Tuingids artikelen">
      <div class="container">
        <div class="section-header reveal">
          <div>
            <p class="section-label">Tuingids &amp; tips</p>
            <h2 class="section-title">Praktisch tuinadvies</h2>
          </div>
          <Button href="/blog" variant="secondary">Alle artikelen</Button>
        </div>
        <div class="blog-grid">
          {recentPosts.map((post, i) => (
            <Card href={`/blog/${post.id.replace(/\.md$/, '')}`} class={`blog-card reveal delay-${(i+1)*100}`}>
              <div class="blog-card-body">
                <Badge label={post.data.category} variant="primary" />
                <h3 class="blog-card-title">{post.data.title}</h3>
                <p class="blog-card-desc">{post.data.description}</p>
                <time class="blog-card-date" datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ════════════════════ CTA BANNER ════════════════════ -->
  <section class="section-gap" aria-label="Offerte aanvragen">
    <div class="container">
      <div class="cta-banner reveal">
        <div class="cta-banner-text">
          <p class="section-label" style="color: var(--color-primary-300)">Klaar om te beginnen?</p>
          <h2>Vergelijk gratis en vrijblijvend</h2>
          <p>Binnen 48 uur bericht van 3 hoveniers uit jouw regio. Geen verplichtingen.</p>
        </div>
        <Button href="/offerte" size="lg">Vraag gratis offertes aan</Button>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── STATS ─────────────────────────────────────────────────────────── */
  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.5rem 2rem;
    flex: 1;
    min-width: 130px;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary-500);
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--color-charcoal-muted);
    text-align: center;
  }

  .stat-divider {
    width: 1px;
    background: var(--color-border);
    margin: 1rem 0;
  }

  /* ─── HOW IT WORKS ──────────────────────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .steps-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .step-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    padding: 2rem;
    position: relative;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .step-card:hover {
    border-color: var(--color-primary-200);
    box-shadow: var(--shadow-md);
  }

  .step-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-primary-50);
    border-radius: var(--radius-md);
    color: var(--color-primary-500);
    margin-bottom: 1rem;
  }

  .step-num {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-canvas-muted);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .step-title {
    font-size: 1.0625rem;
    margin: 0 0 0.5rem;
    color: var(--color-charcoal);
  }

  .step-desc {
    color: var(--color-charcoal-light);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.65;
  }

  /* ─── CALCULATORS ──────────────────────────────────────────────────── */
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .calc-grid { grid-template-columns: repeat(3, 1fr); }
  }

  :global(.calc-card) { display: flex; flex-direction: column; gap: 0.75rem; }

  .calc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-primary-50);
    border-radius: var(--radius-md);
    color: var(--color-primary-500);
  }

  .calc-title {
    font-size: 1.0625rem;
    margin: 0;
    color: var(--color-charcoal);
  }

  .calc-desc {
    color: var(--color-charcoal-light);
    font-size: 0.875rem;
    margin: 0;
    flex: 1;
    line-height: 1.65;
  }

  .calc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary-500);
    margin-top: auto;
    transition: gap var(--transition-fast), color var(--transition-fast);
  }

  :global(.calc-card:hover) .calc-link {
    gap: 0.5rem;
    color: var(--color-primary-600);
  }

  /* ─── SECTION HEADERS ──────────────────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .section-title {
    margin-bottom: 0.25rem;
    color: var(--color-charcoal);
  }

  .section-subtitle {
    color: var(--color-charcoal-light);
    margin: 0.25rem 0 0;
    font-size: 1rem;
  }

  /* ─── BLOG ─────────────────────────────────────────────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .blog-card-body { display: flex; flex-direction: column; gap: 0.625rem; }
  .blog-card-title { font-size: 1rem; margin: 0; color: var(--color-charcoal); }

  .blog-card-desc {
    font-size: 0.875rem;
    color: var(--color-charcoal-light);
    margin: 0;
    flex: 1;
    line-height: 1.6;
  }

  .blog-card-date {
    font-size: 0.78rem;
    color: var(--color-charcoal-muted);
    margin-top: 0.25rem;
  }

  /* ─── CTA BANNER ────────────────────────────────────────────────────── */
  .cta-banner {
    position: relative;
    background: var(--color-charcoal);
    border-radius: var(--radius-2xl);
    padding: 3rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .cta-banner-text {
    position: relative;
  }

  .cta-banner-text h2 {
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }

  .cta-banner-text p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    max-width: 480px;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro'
import OfferteFormulier from '../../islands/OfferteFormulier'

const seo = {
  title: 'Gratis offertes aanvragen | TuinHub',
  description: 'Vraag gratis offertes aan bij hoveniers in jouw regio. Vul je wensen in en ontvang binnen 48 uur maximaal 3 passende offertes.',
}
---

<BaseLayout {seo}>
  <div class="offerte-page section-gap">
    <div class="container offerte-inner">
      <div class="offerte-hero reveal">
        <p class="section-label">Gratis & vrijblijvend</p>
        <h1>Vraag offertes aan</h1>
        <p class="offerte-sub">Vul je wensen in en ontvang binnen 48 uur maximaal 3 offertes van hoveniers bij jou in de buurt.</p>
        <div class="offerte-trust">
          <span>✅ Gratis en vrijblijvend</span>
          <span>🔒 Geen spam</span>
          <span>⏱ 2 minuten</span>
        </div>
      </div>

      <div class="offerte-card reveal delay-100">
        <OfferteFormulier client:load />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .offerte-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 860px;
  }

  @media (min-width: 768px) {
    .offerte-inner {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .offerte-hero h1 { margin: 0.25rem 0 0.75rem; }

  .offerte-sub {
    font-size: 1.0625rem;
    color: rgba(237,242,236,0.58);
    margin: 0 0 1.25rem;
    line-height: 1.7;
  }

  .offerte-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    opacity: 0.80;
  }

  /* Glass container for the React island */
  .offerte-card {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: var(--radius-xl);
    box-shadow: 0 16px 48px rgba(0,0,0,0.35);
    padding: 2rem;
  }
</style>

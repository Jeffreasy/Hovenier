---
import BaseLayout from '../../layouts/BaseLayout.astro'
import OfferteFormulier from '../../islands/OfferteFormulier'

const seo = {
  title: 'Gratis offertes aanvragen | TuinHub',
  description: 'Vraag gratis offertes aan bij hoveniers in jouw regio. Vul je wensen in en ontvang binnen 48 uur maximaal 3 passende offertes.',
}
---

<BaseLayout {seo}>
  <div class="offerte-page section-gap">
    <div class="container offerte-inner">
      <div class="offerte-hero reveal">
        <p class="section-label">Gratis & vrijblijvend</p>
        <h1>Vraag offertes aan</h1>
        <p class="offerte-sub">
          Vul je wensen in en ontvang binnen 48 uur maximaal 3 offertes van hoveniers bij jou in de buurt.
        </p>
        <div class="offerte-trust">
          <span class="offerte-trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            Gratis en vrijblijvend
          </span>
          <span class="offerte-trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Geen spam
          </span>
          <span class="offerte-trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            2 minuten
          </span>
        </div>
      </div>

      <div class="offerte-card reveal delay-100">
        <OfferteFormulier client:load />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .offerte-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 860px;
  }

  @media (min-width: 768px) {
    .offerte-inner {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .offerte-hero h1 { margin: 0.25rem 0 0.75rem; color: var(--color-charcoal); }

  .offerte-sub {
    font-size: 1.0625rem;
    color: var(--color-charcoal-light);
    margin: 0 0 1.25rem;
    line-height: 1.7;
  }

  .offerte-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-charcoal-light);
  }

  .offerte-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .offerte-trust-item svg {
    color: var(--color-primary-500);
  }

  /* Clean card for the React island */
  .offerte-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    box-shadow: var(--shadow-md);
    padding: 2rem;
  }
</style>

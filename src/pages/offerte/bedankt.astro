---
import BaseLayout from '../../layouts/BaseLayout.astro'

const seo = {
  title: 'Bedankt voor uw aanvraag',
  description: 'Uw offerte-aanvraag is ontvangen. We nemen binnen 24 uur contact op.',
  noindex: true,
}
---

<BaseLayout {seo}>
  <div class="bedankt-page section-gap">
    <div class="container bedankt-inner">
      <div class="bedankt-card reveal">
        <div class="bedankt-icon" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
            <circle cx="28" cy="28" r="28" fill="var(--color-primary-50)" />
            <path d="M17 28.5L24.5 36L39 21" stroke="var(--color-primary-500)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>

        <h1>Bedankt voor uw aanvraag!</h1>

        <p class="bedankt-text">
          We hebben uw gegevens in goede orde ontvangen. We bekijken uw project
          zorgvuldig en nemen (indien nodig) kort telefonisch contact op om de
          details af te stemmen. Daarna zoeken we in ons netwerk naar de beste
          hoveniers voor uw klus.
        </p>

        <p class="bedankt-email">
          U ontvangt ook een bevestiging per e-mail.
        </p>

        <div class="bedankt-actions">
          <a href="/" class="btn-primary bedankt-btn">Terug naar home</a>
          <a href="/tools/tuinkosten-calculator" class="bedankt-btn bedankt-btn--secondary">Tuinkosten calculator</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .bedankt-inner {
    max-width: 620px;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  .bedankt-card {
    text-align: center;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    box-shadow: var(--shadow-md);
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .bedankt-icon { margin-bottom: 0.5rem; }

  .bedankt-card h1 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-charcoal);
    margin: 0;
  }

  .bedankt-text {
    color: var(--color-charcoal-light);
    line-height: 1.75;
    max-width: 480px;
    margin: 0;
    font-size: 1rem;
  }

  .bedankt-email {
    color: var(--color-charcoal-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .bedankt-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
    justify-content: center;
  }

  .bedankt-btn {
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.15s ease-out;
  }

  .bedankt-btn--secondary {
    background: var(--color-canvas-alt);
    color: var(--color-charcoal-light);
    border: 1px solid var(--color-border);
  }

  .bedankt-btn--secondary:hover {
    border-color: var(--color-border-hover);
    color: var(--color-charcoal);
    background: var(--color-canvas-muted);
  }
</style>

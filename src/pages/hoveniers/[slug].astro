---
export const prerender = false
import BaseLayout from '../../layouts/BaseLayout.astro'
import { breadcrumbSchema } from '../../lib/seo'

const { slug } = Astro.params

// Haal bedrijf op via Convex HTTP API
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
let bedrijf: Record<string, any> | null = null

if (convexUrl && slug) {
  try {
    const res = await fetch(`${convexUrl}/api/query`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        path:   'bedrijven:getBySlug',
        args:   { slug },
        format: 'json',
      }),
    })
    const data = await res.json()
    bedrijf = data.value ?? null
  } catch {
    // graceful degradation — 404 hieronder
  }
}

if (!bedrijf) {
  return Astro.redirect('/404', 302)
}

// Categorie labels
const catLabel: Record<string, string> = {
  'Tuin': 'Tuin',
  'Tuin- en landschapaannemer': 'Tuinaannemer',
  'Tuin- en landschapsaannemer': 'Tuinaannemer',
  'Tuin- en landschapsarchitect': 'Tuinaannemer',
  'Hoveniersbedrijf': 'Hovenier',
  'Hovenier': 'Hovenier',
  'Landschapsarchitect': 'Landschapsarchitect',
  'Boomverzorging': 'Boomverzorging',
  'Boomverzorgingsdienst': 'Boomverzorging',
  'Tuinaannemer': 'Tuinaannemer',
  'Tuinonderhoud': 'Tuinonderhoud',
  'Tuinman': 'Tuinman',
  'Tuinarchitect': 'Tuinaannemer',
}

const hoofdLabel = catLabel[bedrijf.hoofdCategorie] ?? bedrijf.hoofdCategorie ?? 'Hovenier'

const seo = {
  title: `${bedrijf.naam} | ${hoofdLabel} in ${bedrijf.stad ?? 'Nederland'}`,
  description: `${bedrijf.naam} in ${bedrijf.stad ?? 'Nederland'} · Google score ${bedrijf.googleScore ?? '?'}/5 · ${bedrijf.aantalReviews ?? 0} reviews. Vraag gratis offerte aan via TuinHub.`,
}

// Bouw offerte URL
const offerteUrl = `/offerte?${new URLSearchParams({
  postcode: bedrijf.postcode ?? '',
  stad:     (bedrijf.stad ?? '').toLowerCase(),
  bedrijf:  bedrijf.naam,
}).toString()}`

// Template beschrijving als beschrijving ontbreekt
const scoreText    = bedrijf.googleScore ? `een Google-score van ${bedrijf.googleScore.toFixed(1)}/5` : 'professionele service'
const reviewText   = bedrijf.aantalReviews ? ` op basis van ${bedrijf.aantalReviews} klantbeoordelingen` : ''
const stadtText    = bedrijf.stad ? ` in ${bedrijf.stad}${bedrijf.provincie ? ` (${bedrijf.provincie})` : ''}` : ' in Nederland'
const beschrijving = bedrijf.beschrijving ??
  `${bedrijf.naam} is een professioneel ${hoofdLabel.toLowerCase()}-bedrijf${stadtText}. ` +
  `Met ${scoreText}${reviewText} staan zij bekend om vakmanschap en betrouwbaarheid. ` +
  `Vraag via TuinHub vrijblijvend een offerte aan en vergelijk tot 3 hoveniers gratis.`

// Star rating helpers
const fullStars = Math.floor(bedrijf.googleScore ?? 0)
const hasHalf   = (bedrijf.googleScore ?? 0) - fullStars >= 0.25
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0)

const localBusinessLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: bedrijf.naam,
  address: {
    '@type': 'PostalAddress',
    addressLocality: bedrijf.stad ?? '',
    addressRegion: bedrijf.provincie ?? '',
    postalCode: bedrijf.postcode ?? '',
    addressCountry: 'NL',
  },
  url: bedrijf.website ?? undefined,
  telephone: bedrijf.telefoon ?? undefined,
  aggregateRating: bedrijf.googleScore ? {
    '@type': 'AggregateRating',
    ratingValue: bedrijf.googleScore,
    reviewCount: bedrijf.aantalReviews ?? 1,
    bestRating: 5,
    worstRating: 1,
  } : undefined,
})

const breadcrumbLd = breadcrumbSchema([
  { name: 'Home',       href: '/' },
  { name: 'Hoveniers',  href: '/hoveniers' },
  ...(bedrijf.stad ? [{ name: bedrijf.stad, href: `/steden/${(bedrijf.stad as string).toLowerCase()}` }] : []),
  { name: bedrijf.naam, href: `/hoveniers/${slug}` },
])

const jsonLd = [localBusinessLd, breadcrumbLd].join('\n')
---

<BaseLayout {seo}>
  <script is:inline type="application/ld+json" set:html={jsonLd} />

  <section class="profiel-section section-gap">
    <div class="container profiel-container">

      <!-- Breadcrumb -->
      <nav class="profiel-breadcrumb" aria-label="Navigatie">
        <a href="/">Home</a>
        <span aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
        {bedrijf.stad && (
          <>
            <a href={`/steden/${(bedrijf.stad).toLowerCase()}`}>{bedrijf.stad}</a>
            <span aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </>
        )}
        <span aria-current="page">{bedrijf.naam}</span>
      </nav>

      <!-- Hero card -->
      <header class="profiel-hero">
        <div class="profiel-hero-body">
          <span class="profiel-badge">{hoofdLabel}</span>
          <h1 class="profiel-naam">{bedrijf.naam}</h1>

          {bedrijf.googleScore && (
            <div class="profiel-score" aria-label={`Google score: ${bedrijf.googleScore} uit 5`}>
              <span class="profiel-stars" aria-hidden="true">
                {Array.from({ length: fullStars }).map(() => (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" stroke="none">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
                {hasHalf && (
                  <svg width="18" height="18" viewBox="0 0 24 24" stroke="none">
                    <defs><clipPath id="half"><rect x="0" y="0" width="12" height="24"/></clipPath></defs>
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#e2e8f0"/>
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#f59e0b" clip-path="url(#half)"/>
                  </svg>
                )}
                {Array.from({ length: emptyStars }).map(() => (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="#e2e8f0" stroke="none">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </span>
              <strong>{bedrijf.googleScore.toFixed(1)}</strong>
              <span class="profiel-reviews">
                {bedrijf.aantalReviews ? `${bedrijf.aantalReviews} Google-reviews` : 'op Google'}
              </span>
            </div>
          )}

          <div class="profiel-meta-row">
            {bedrijf.stad && (
              <span class="profiel-meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {bedrijf.stad}{bedrijf.provincie ? `, ${bedrijf.provincie}` : ''}
              </span>
            )}
            {bedrijf.postcode && (
              <span class="profiel-meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                {bedrijf.postcode}
              </span>
            )}
            {bedrijf.telefoon && (
              <span class="profiel-meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href={`tel:${bedrijf.telefoon}`}>{bedrijf.telefoon}</a>
              </span>
            )}
          </div>

          <!-- Beschrijving -->
          <p class="profiel-beschrijving">{beschrijving}</p>
        </div>

        <div class="profiel-cta">
          <a href={offerteUrl} class="btn-primary profiel-offerte-btn">
            Offerte aanvragen
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          {bedrijf.googleMapsUrl && (
            <a href={bedrijf.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="profiel-ghost-btn">
              Bekijk op Google Maps
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
          )}
          {bedrijf.website && (
            <a
              href={bedrijf.website.startsWith('http') ? bedrijf.website : `https://${bedrijf.website}`}
              target="_blank"
              rel="noopener noreferrer"
              class="profiel-ghost-btn"
            >
              Website bezoeken
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
          )}
        </div>
      </header>

      <!-- Info grid -->
      <div class="profiel-grid">
        <!-- Specialisaties -->
        {bedrijf.categorieen?.length > 0 && (
          <div class="profiel-card">
            <h2 class="profiel-card-title">Specialisaties</h2>
            <ul class="profiel-cat-list">
              {bedrijf.categorieen.map((cat: string) => (
                <li class="profiel-cat-item">{catLabel[cat] ?? cat}</li>
              ))}
            </ul>
          </div>
        )}

        <!-- Locatie info -->
        <div class="profiel-card">
          <h2 class="profiel-card-title">Locatie</h2>
          <div class="profiel-info-list">
            {bedrijf.stad && <div class="profiel-info-row"><span>Stad</span><strong>{bedrijf.stad}</strong></div>}
            {bedrijf.provincie && <div class="profiel-info-row"><span>Provincie</span><strong>{bedrijf.provincie}</strong></div>}
            {bedrijf.postcode && <div class="profiel-info-row"><span>Postcode</span><strong>{bedrijf.postcode}</strong></div>}
          </div>
        </div>

        <!-- Contact -->
        {(bedrijf.telefoon || bedrijf.website) && (
          <div class="profiel-card">
            <h2 class="profiel-card-title">Contact</h2>
            <div class="profiel-info-list">
              {bedrijf.telefoon && (
                <div class="profiel-info-row">
                  <span>Telefoon</span>
                  <a href={`tel:${bedrijf.telefoon}`} class="profiel-link">{bedrijf.telefoon}</a>
                </div>
              )}
              {bedrijf.website && (
                <div class="profiel-info-row">
                  <span>Website</span>
                  <a
                    href={bedrijf.website.startsWith('http') ? bedrijf.website : `https://${bedrijf.website}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="profiel-link"
                  >
                    {bedrijf.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}
                  </a>
                </div>
              )}
            </div>
          </div>
        )}
      </div>

      <!-- Bottom CTA -->
      <div class="profiel-bottom-cta">
        <div>
          <h2>Interesse in {bedrijf.naam}?</h2>
          <p>Vraag via TuinHub een gratis en vrijblijvende offerte aan. Je ontvangt binnen 48 uur maximaal 3 offertes.</p>
        </div>
        <a href={offerteUrl} class="btn-primary profiel-offerte-btn">
          Offerte aanvragen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .profiel-section { padding-top: 2rem; }
  .profiel-container { max-width: 900px; }

  .profiel-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-charcoal-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .profiel-breadcrumb a {
    color: var(--color-charcoal-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }
  .profiel-breadcrumb a:hover { color: var(--color-primary-500); }
  .profiel-breadcrumb [aria-current] { color: var(--color-charcoal); font-weight: 500; }
  .profiel-breadcrumb svg { color: var(--color-charcoal-muted); }

  .profiel-hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2rem;
    margin-bottom: 1.5rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    box-shadow: var(--shadow-md);
  }

  .profiel-hero-body { flex: 1; min-width: 240px; }

  .profiel-badge {
    display: inline-flex;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-200);
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary-700);
    margin-bottom: 0.75rem;
  }

  .profiel-naam {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 800;
    color: var(--color-charcoal);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .profiel-score {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
  }
  .profiel-stars { display: flex; align-items: center; gap: 1px; }
  .profiel-score strong { color: var(--color-charcoal); font-weight: 700; font-size: 1.125rem; }
  .profiel-reviews { color: var(--color-charcoal-muted); font-size: 0.875rem; }

  .profiel-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }
  .profiel-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-charcoal-light);
  }
  .profiel-meta-item svg { color: var(--color-charcoal-muted); }
  .profiel-meta-item a { color: inherit; text-decoration: none; }
  .profiel-meta-item a:hover { color: var(--color-primary-500); }

  .profiel-beschrijving {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-charcoal-light);
    margin: 0.875rem 0 0;
    max-width: 520px;
  }

  .profiel-cta {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    min-width: 200px;
  }

  .profiel-offerte-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .profiel-ghost-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-charcoal-light);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
    white-space: nowrap;
  }
  .profiel-ghost-btn:hover {
    border-color: var(--color-border-hover);
    color: var(--color-charcoal);
    background: var(--color-canvas-alt);
  }

  .profiel-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) {
    .profiel-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .profiel-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .profiel-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
  }

  .profiel-card-title {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-charcoal-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.875rem;
  }

  .profiel-cat-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .profiel-cat-item {
    padding: 0.25rem 0.625rem;
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-200);
    border-radius: 99px;
    font-size: 0.8rem;
    color: var(--color-primary-700);
  }

  .profiel-info-list { display: flex; flex-direction: column; gap: 0.625rem; }
  .profiel-info-row {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.875rem;
  }
  .profiel-info-row span { color: var(--color-charcoal-muted); }
  .profiel-info-row strong { color: var(--color-charcoal); font-weight: 600; text-align: right; }
  .profiel-link {
    color: var(--color-primary-600);
    text-decoration: none;
    font-weight: 600;
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 180px;
  }
  .profiel-link:hover { text-decoration: underline; }

  .profiel-bottom-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 2rem;
    background: var(--color-charcoal);
    border-radius: var(--radius-box);
  }
  .profiel-bottom-cta h2 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0 0 0.375rem;
  }
  .profiel-bottom-cta p {
    color: rgba(255,255,255,0.65);
    font-size: 0.875rem;
    margin: 0;
    max-width: 480px;
  }
</style>

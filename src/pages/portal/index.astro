---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const { getToken } = Astro.locals.auth()
const clerkToken = await getToken({ template: 'convex' }) ?? ''
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  <title>Dashboard | Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <!-- Header -->
  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/" class="portal-logo">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#008d51" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-7.5 8-13-2 1-3.5 1-5.5 0C10 8.5 8 11 7 14c-1.5 3-2 5-2 6"/><path d="M12 20c-2-2.5-3-5-3-8 2 .5 3.5 1 5 .5"/></svg>
        <span>TuinHub</span>
      </a>
      <nav class="portal-nav">
        <a href="/portal" class="portal-nav-link portal-nav-link--active">Dashboard</a>
        <a href="/portal/profiel" class="portal-nav-link">Mijn profiel</a>
      </nav>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="portal-main">
    <div class="portal-container">

      <div class="page-header">
        <h1>Jouw leads</h1>
        <p class="page-sub">Overzicht van alle offerte-aanvragen die bij jou passen.</p>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        {[
          { label: 'Nieuw',      color: '#3b82f6', id: 'nieuw' },
          { label: 'In contact', color: '#f59e0b', id: 'contact' },
          { label: 'Gesloten',   color: '#10b981', id: 'gesloten' },
        ].map((s) => (
          <div class="stat-card" id={`stat-${s.id}`}>
            <span class="stat-dot" style={`background: ${s.color};`}></span>
            <span class="stat-label">{s.label}</span>
            <strong class="stat-value" id={`count-${s.id}`}>&mdash;</strong>
          </div>
        ))}
      </div>

      <!-- Leads lijst -->
      <div id="leads-list" class="leads-list">
        <div class="leads-loading">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
          Leads laden...
        </div>
      </div>

    </div>
  </main>

  <script define:vars={{ convexUrl, clerkToken }}>
    async function loadLeads() {
      const list = document.getElementById('leads-list')
      if (!list) return
      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({ path: 'leads:getMyLeads', args: {}, format: 'json' }),
        })
        const { value: leads } = await res.json()

        const counts = { nieuw: 0, contact: 0, gesloten: 0 }
        leads.forEach(l => { if (l.status in counts) counts[l.status]++ })
        Object.entries(counts).forEach(([k, v]) => {
          const el = document.getElementById(`count-${k}`)
          if (el) el.textContent = String(v)
        })

        if (!leads.length) {
          list.innerHTML = `<div class="leads-empty"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg><p>Nog geen leads toegewezen. Je ontvangt een e-mail zodra er een aanvraag binnenkomt.</p></div>`
          return
        }

        list.innerHTML = leads.map(l => `
          <a href="/portal/leads/${l._id}" class="lead-card">
            <div class="lead-card-left">
              <span class="lead-status lead-status--${l.status}">${l.status}</span>
              <strong class="lead-naam">${l.naam}</strong>
              <span class="lead-meta">${l.postcode} · ${l.dienst} · ${l.m2} m²</span>
            </div>
            <div class="lead-card-right">
              <span class="lead-budget">${l.budget}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </div>
          </a>
        `).join('')
      } catch {
        list.innerHTML = `<div class="leads-empty"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>Laden mislukt. Ververs de pagina.</p></div>`
      }
    }
    loadLeads()
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #f8fafc;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .portal-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #282d31;
    text-decoration: none;
    flex-shrink: 0;
  }

  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }

  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    transition: all 0.15s;
  }

  .portal-nav-link:hover { background: #f1f5f9; color: #282d31; }

  .portal-nav-link--active {
    background: rgba(0,141,81,0.08);
    color: #008d51;
    font-weight: 600;
  }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 1100px; margin: 0 auto; }

  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #282d31; }
  .page-sub { margin-top: 0.375rem; color: #475569; }

  /* ── Stat cards ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color 0.15s;
  }

  .stat-card:hover { border-color: #cbd5e1; }

  .stat-dot { width: 10px; height: 10px; border-radius: 50%; }
  .stat-label { font-size: 0.8rem; color: #475569; font-weight: 500; }
  .stat-value { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #008d51; }

  /* ── Lead list ── */
  .leads-list { display: flex; flex-direction: column; gap: 0.625rem; }

  .leads-loading, .leads-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    color: #475569;
    font-size: 0.9rem;
    text-align: center;
  }

  .leads-empty svg { color: #94a3b8; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }

  .lead-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .lead-card:hover {
    border-color: #cbd5e1;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transform: translateY(-1px);
  }

  .lead-card-left { display: flex; flex-direction: column; gap: 0.25rem; }
  .lead-naam { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; color: #282d31; }
  .lead-meta { font-size: 0.8rem; color: #94a3b8; }
  .lead-card-right { display: flex; align-items: center; gap: 0.5rem; color: #94a3b8; }
  .lead-budget { font-size: 0.875rem; color: #008d51; font-weight: 600; }

  .lead-status {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    width: fit-content;
  }

  .lead-status--nieuw    { background: rgba(59,130,246,0.10);  color: #2563eb; }
  .lead-status--contact  { background: rgba(245,158,11,0.10);  color: #d97706; }
  .lead-status--gesloten { background: rgba(16,185,129,0.10);  color: #059669; }

  @media (max-width: 640px) {
    .stats-row { grid-template-columns: 1fr; }
  }
</style>

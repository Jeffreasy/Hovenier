---
export const prerender = false
import PortalLayout from '../../layouts/PortalLayout.astro'


const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
const userId = Astro.locals.user?.id ?? ''
const userEmail = Astro.locals.user?.email ?? ''
---

<PortalLayout title="Dashboard" activeNav="dashboard">

  <div class="page-header">
    <h1>Jouw leads</h1>
    <p class="page-sub">Overzicht van alle offerte-aanvragen die bij jou passen.</p>
  </div>

  <!-- Claim CTA (als geen bedrijf geclaimd) -->
  <div id="claim-cta" class="claim-cta" style="display:none;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <div class="claim-cta-text">
      <strong>Nog geen bedrijf gekoppeld</strong>
      <span>Koppel je account aan je hoveniersbedrijf om leads te ontvangen.</span>
    </div>
    <a href="/portal/profiel" class="claim-cta-btn">Bedrijf koppelen</a>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    {[
      { label: 'Nieuw',           color: '#3b82f6', id: 'nieuw' },
      { label: 'Klant gesproken', color: '#f59e0b', id: 'klant_gesproken' },
      { label: 'Gematcht',        color: '#10b981', id: 'gematcht' },
      { label: 'Vervallen',       color: '#94a3b8', id: 'vervallen' },
    ].map((s) => (
      <div class="stat-card" id={`stat-${s.id}`}>
        <span class="stat-dot" style={`background: ${s.color};`}></span>
        <span class="stat-label">{s.label}</span>
        <strong class="stat-value" id={`count-${s.id}`}>&mdash;</strong>
      </div>
    ))}
  </div>

  <!-- Leads lijst -->
  <div id="leads-list" class="leads-list">
    <div class="leads-loading">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      Leads laden...
    </div>
  </div>

  <script define:vars={{ convexUrl, userId, userEmail }}>
    /** Escape HTML entities to prevent XSS */
    function esc(str) {
      const div = document.createElement('div')
      div.textContent = String(str ?? '')
      return div.innerHTML
    }

    const STATUS_LABELS = {
      nieuw: 'Nieuw',
      klant_gesproken: 'Klant gesproken',
      gematcht: 'Gematcht',
      vervallen: 'Vervallen',
    }

    async function loadLeads() {
      const list = document.getElementById('leads-list')
      if (!list) return
      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path: 'leads:getMyLeads', args: { userId }, format: 'json' }),
        })
        const { value: leads } = await res.json()

        const counts = { nieuw: 0, klant_gesproken: 0, gematcht: 0, vervallen: 0 }
        leads.forEach(l => { if (l.status in counts) counts[l.status]++ })
        Object.entries(counts).forEach(([k, v]) => {
          const el = document.getElementById(`count-${k}`)
          if (el) el.textContent = String(v)
        })

        if (!leads.length) {
          list.innerHTML = `<div class="leads-empty"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg><p>Nog geen leads toegewezen. Je ontvangt een e-mail zodra er een aanvraag binnenkomt.</p></div>`
          return
        }

        list.innerHTML = leads.map(l => `
          <a href="/portal/leads/${esc(l._id)}" class="lead-card">
            <div class="lead-card-left">
              <span class="lead-status lead-status--${esc(l.status)}">${esc(STATUS_LABELS[l.status] ?? l.status)}</span>
              <strong class="lead-naam">${esc(l.naam)}</strong>
              <span class="lead-meta">${l.bedrijf_naam ? esc(l.bedrijf_naam) + ' &middot; ' : ''}${esc(l.postcode)} &middot; ${esc(l.dienst)} &middot; ${esc(l.m2)} m&sup2;</span>
            </div>
            <div class="lead-card-right">
              <span class="lead-budget">${esc(l.budget)}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </div>
          </a>
        `).join('')
      } catch {
        list.innerHTML = `<div class="leads-empty"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>Laden mislukt. Ververs de pagina.</p></div>`
      }
    }
    loadLeads()
    checkClaimStatus()
  </script>

</PortalLayout>

<!-- Check if bedrijf is claimed -->
<script define:vars={{ convexUrl, userId }}>
  async function checkClaimStatus() {
    try {
      const res = await fetch(`${convexUrl}/api/query`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path: 'bedrijven:getMyBedrijf', args: { userId }, format: 'json' }),
      })
      const { value: bedrijf } = await res.json()
      if (!bedrijf) {
        const cta = document.getElementById('claim-cta')
        if (cta) cta.style.display = 'flex'
      }
    } catch {}
  }
  checkClaimStatus()
</script>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #282d31; }
  .page-sub { margin-top: 0.375rem; color: #475569; }

  /* ── Claim CTA ── */
  .claim-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(245,158,11,0.06);
    border: 1px solid rgba(245,158,11,0.20);
    border-radius: 12px;
    margin-bottom: 1.5rem;
    color: #d97706;
  }

  .claim-cta-text { display: flex; flex-direction: column; gap: 0.125rem; flex: 1; }
  .claim-cta-text strong { font-size: 0.875rem; color: #92400e; }
  .claim-cta-text span { font-size: 0.8rem; color: #b45309; }

  .claim-cta-btn {
    padding: 0.5rem 1rem;
    background: #d97706;
    color: #ffffff;
    border-radius: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .claim-cta-btn:hover { background: #b45309; }

  /* ── Stat cards ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color 0.15s;
  }

  .stat-card:hover { border-color: #cbd5e1; }

  .stat-dot { width: 10px; height: 10px; border-radius: 50%; }
  .stat-label { font-size: 0.8rem; color: #475569; font-weight: 500; }
  .stat-value { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #008d51; }

  /* ── Lead list ── */
  .leads-list { display: flex; flex-direction: column; gap: 0.625rem; }

  .leads-loading, .leads-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    color: #475569;
    font-size: 0.9rem;
    text-align: center;
  }

  .leads-empty svg { color: #94a3b8; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }

  .lead-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .lead-card:hover {
    border-color: #cbd5e1;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transform: translateY(-1px);
  }

  .lead-card-left { display: flex; flex-direction: column; gap: 0.25rem; }
  .lead-naam { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; color: #282d31; }
  .lead-meta { font-size: 0.8rem; color: #94a3b8; }
  .lead-card-right { display: flex; align-items: center; gap: 0.5rem; color: #94a3b8; }
  .lead-budget { font-size: 0.875rem; color: #008d51; font-weight: 600; }

  .lead-status {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    width: fit-content;
  }

  .lead-status--nieuw            { background: rgba(59,130,246,0.10);  color: #2563eb; }
  .lead-status--klant_gesproken  { background: rgba(245,158,11,0.10);  color: #d97706; }
  .lead-status--gematcht         { background: rgba(16,185,129,0.10);  color: #059669; }
  .lead-status--vervallen        { background: rgba(148,163,184,0.10); color: #64748b; }

  @media (max-width: 640px) {
    .stats-row { grid-template-columns: 1fr; }
  }
</style>

---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

// Auth — middleware zorgt ervoor dat je hier alleen binnenkomt als ingelogd
const user = (Astro.locals as Record<string, unknown> & { auth?: () => { userId?: string } }).auth?.()
const clerkId = user?.userId ?? ''

// Fetch leads van Convex
// NOTE: We fetchen server-side via de Convex HTTP endpoint
// In een latere iteratie kun je hier de Convex client SDK gebruiken.
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''

// Voor server-side data fetching van Convex queries gebruiken we de REST API
// Tijdelijk: leeg array — data wordt geladen via client-side island
const leads: unknown[] = []
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard — Hovenier Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <!-- Header -->
  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/" class="portal-logo">🌿 Tuinplatform</a>
      <nav class="portal-nav">
        <a href="/portal" class="portal-nav-link portal-nav-link--active">Dashboard</a>
        <a href="/portal/profiel" class="portal-nav-link">Mijn profiel</a>
      </nav>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="portal-main">
    <div class="portal-container">

      <!-- Page header -->
      <div class="page-header">
        <h1>Jouw leads</h1>
        <p class="page-sub">Overzicht van alle offerte-aanvragen die bij jou passen.</p>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        {[
          { label: 'Nieuw',     emoji: '🔵', id: 'nieuw' },
          { label: 'In contact',emoji: '🟡', id: 'contact' },
          { label: 'Gesloten',  emoji: '🟢', id: 'gesloten' },
        ].map((s) => (
          <div class="stat-card" id={`stat-${s.id}`}>
            <span class="stat-emoji">{s.emoji}</span>
            <span class="stat-label">{s.label}</span>
            <strong class="stat-value" id={`count-${s.id}`}>—</strong>
          </div>
        ))}
      </div>

      <!-- Leads lijst (geladen via client-side script) -->
      <div id="leads-list" class="leads-list">
        <div class="leads-loading">
          <span>⏳</span> Leads laden…
        </div>
      </div>

    </div>
  </main>

  <!-- Client-side script: laadt leads via Convex HTTP -->
  <script define:vars={{ convexUrl, clerkId }}>
    async function loadLeads() {
      const list = document.getElementById('leads-list')
      if (!list) return

      try {
        // Convex query via HTTP API (read-only)
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            path: 'leads:getMyLeads',
            args: { clerkId },
            format: 'json',
          }),
        })
        const { value: leads } = await res.json()

        // Update stats
        const counts = { nieuw: 0, contact: 0, gesloten: 0 }
        leads.forEach(l => { if (l.status in counts) counts[l.status]++ })
        Object.entries(counts).forEach(([k, v]) => {
          const el = document.getElementById(`count-${k}`)
          if (el) el.textContent = String(v)
        })

        // Render leads
        if (!leads.length) {
          list.innerHTML = `<div class="leads-empty">
            <span>📭</span>
            <p>Nog geen leads toegewezen. Je ontvangt een e-mail zodra er een aanvraag binnenkomt.</p>
          </div>`
          return
        }

        list.innerHTML = leads.map(l => `
          <a href="/portal/leads/${l._id}" class="lead-card">
            <div class="lead-card-left">
              <span class="lead-status lead-status--${l.status}">${l.status}</span>
              <strong class="lead-naam">${l.naam}</strong>
              <span class="lead-meta">${l.postcode} · ${l.dienst} · ${l.m2} m²</span>
            </div>
            <div class="lead-card-right">
              <span class="lead-budget">${l.budget}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </div>
          </a>
        `).join('')

      } catch (err) {
        list.innerHTML = `<div class="leads-empty"><span>⚠</span><p>Laden mislukt. Ververs de pagina.</p></div>`
      }
    }

    loadLeads()
  </script>

</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    background: #F5F3EF;
    font-family: 'Inter', sans-serif;
    color: #2D2D2D;
  }

  /* Header */
  .portal-header {
    background: white;
    border-bottom: 1px solid #E5E5E5;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .portal-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #3D5438;
    text-decoration: none;
    flex-shrink: 0;
  }
  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }
  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6B7280;
    text-decoration: none;
    transition: all 0.15s;
  }
  .portal-nav-link:hover { background: #E8F0E4; color: #3D5438; }
  .portal-nav-link--active { background: #E8F0E4; color: #3D5438; font-weight: 600; }
  .portal-user { margin-left: auto; }

  /* Main */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 1100px; margin: 0 auto; }

  /* Page header */
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; }
  .page-sub { margin-top: 0.375rem; color: #6B7280; }

  /* Stats */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: white;
    border-radius: 12px;
    padding: 1.25rem;
    border: 1px solid #E5E5E5;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-emoji { font-size: 1.25rem; }
  .stat-label { font-size: 0.8rem; color: #6B7280; font-weight: 500; }
  .stat-value { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #3D5438; }

  /* Leads */
  .leads-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .leads-loading, .leads-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem;
    background: white;
    border-radius: 12px;
    color: #6B7280;
    font-size: 0.9rem;
    text-align: center;
    border: 1px solid #E5E5E5;
  }
  .leads-empty span { font-size: 2rem; }

  .lead-card {
    background: white;
    border: 1px solid #E5E5E5;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }
  .lead-card:hover { border-color: #5B7553; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .lead-card-left { display: flex; flex-direction: column; gap: 0.25rem; }
  .lead-naam { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; }
  .lead-meta { font-size: 0.8rem; color: #6B7280; }
  .lead-card-right { display: flex; align-items: center; gap: 0.5rem; color: #6B7280; }
  .lead-budget { font-size: 0.875rem; color: #5B7553; font-weight: 600; }

  .lead-status {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    width: fit-content;
  }
  .lead-status--nieuw    { background: #DBEAFE; color: #1D4ED8; }
  .lead-status--contact  { background: #FEF3C7; color: #D97706; }
  .lead-status--gesloten { background: #D1FAE5; color: #065F46; }

  @media (max-width: 640px) {
    .stats-row { grid-template-columns: 1fr; }
  }
</style>

---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const { getToken } = Astro.locals.auth()
const clerkToken = await getToken({ template: 'convex' }) ?? ''
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dashboard — Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <!-- Header -->
  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/" class="portal-logo">🌿 TuinHub</a>
      <nav class="portal-nav">
        <a href="/portal" class="portal-nav-link portal-nav-link--active">Dashboard</a>
        <a href="/portal/profiel" class="portal-nav-link">Mijn profiel</a>
      </nav>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="portal-main">
    <div class="portal-container">

      <div class="page-header">
        <h1>Jouw leads</h1>
        <p class="page-sub">Overzicht van alle offerte-aanvragen die bij jou passen.</p>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        {[
          { label: 'Nieuw',      emoji: '🔵', id: 'nieuw' },
          { label: 'In contact', emoji: '🟡', id: 'contact' },
          { label: 'Gesloten',   emoji: '🟢', id: 'gesloten' },
        ].map((s) => (
          <div class="stat-card" id={`stat-${s.id}`}>
            <span class="stat-emoji">{s.emoji}</span>
            <span class="stat-label">{s.label}</span>
            <strong class="stat-value" id={`count-${s.id}`}>—</strong>
          </div>
        ))}
      </div>

      <!-- Leads lijst -->
      <div id="leads-list" class="leads-list">
        <div class="leads-loading">
          <span>⏳</span> Leads laden…
        </div>
      </div>

    </div>
  </main>

  <script define:vars={{ convexUrl, clerkToken }}>
    async function loadLeads() {
      const list = document.getElementById('leads-list')
      if (!list) return
      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({ path: 'leads:getMyLeads', args: {}, format: 'json' }),
        })
        const { value: leads } = await res.json()

        const counts = { nieuw: 0, contact: 0, gesloten: 0 }
        leads.forEach(l => { if (l.status in counts) counts[l.status]++ })
        Object.entries(counts).forEach(([k, v]) => {
          const el = document.getElementById(`count-${k}`)
          if (el) el.textContent = String(v)
        })

        if (!leads.length) {
          list.innerHTML = `<div class="leads-empty"><span>📭</span><p>Nog geen leads toegewezen. Je ontvangt een e-mail zodra er een aanvraag binnenkomt.</p></div>`
          return
        }

        list.innerHTML = leads.map(l => `
          <a href="/portal/leads/${l._id}" class="lead-card">
            <div class="lead-card-left">
              <span class="lead-status lead-status--${l.status}">${l.status}</span>
              <strong class="lead-naam">${l.naam}</strong>
              <span class="lead-meta">${l.postcode} · ${l.dienst} · ${l.m2} m²</span>
            </div>
            <div class="lead-card-right">
              <span class="lead-budget">${l.budget}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </div>
          </a>
        `).join('')
      } catch {
        list.innerHTML = `<div class="leads-empty"><span>⚠</span><p>Laden mislukt. Ververs de pagina.</p></div>`
      }
    }
    loadLeads()
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #EDF2EC;
    background:
      radial-gradient(ellipse 80% 60% at 20% -10%, rgba(70,110,60,0.15) 0%, transparent 60%),
      #0D1F12;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: rgba(13,31,18,0.72);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .portal-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #EDF2EC;
    text-decoration: none;
    flex-shrink: 0;
  }

  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }

  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(237,242,236,0.55);
    text-decoration: none;
    transition: all 0.15s;
  }

  .portal-nav-link:hover { background: rgba(255,255,255,0.07); color: #EDF2EC; }

  .portal-nav-link--active {
    background: rgba(110,158,101,0.15);
    color: #EDF2EC;
    font-weight: 600;
  }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 1100px; margin: 0 auto; }

  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #EDF2EC; }
  .page-sub { margin-top: 0.375rem; color: rgba(237,242,236,0.45); }

  /* ── Stat cards ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color 0.15s;
  }

  .stat-card:hover { border-color: rgba(196,169,106,0.25); }

  .stat-emoji { font-size: 1.25rem; }
  .stat-label { font-size: 0.8rem; color: rgba(237,242,236,0.45); font-weight: 500; }
  .stat-value { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #C4A96A; }

  /* ── Lead list ── */
  .leads-list { display: flex; flex-direction: column; gap: 0.625rem; }

  .leads-loading, .leads-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    color: rgba(237,242,236,0.40);
    font-size: 0.9rem;
    text-align: center;
  }

  .leads-empty span { font-size: 2rem; }

  .lead-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
  }

  .lead-card:hover {
    border-color: rgba(196,169,106,0.30);
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }

  .lead-card-left { display: flex; flex-direction: column; gap: 0.25rem; }
  .lead-naam { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; color: #EDF2EC; }
  .lead-meta { font-size: 0.8rem; color: rgba(237,242,236,0.40); }
  .lead-card-right { display: flex; align-items: center; gap: 0.5rem; color: rgba(237,242,236,0.35); }
  .lead-budget { font-size: 0.875rem; color: #C4A96A; font-weight: 600; }

  .lead-status {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    width: fit-content;
  }

  .lead-status--nieuw    { background: rgba(59,130,246,0.15);  color: #93C5FD; }
  .lead-status--contact  { background: rgba(251,191,36,0.15);  color: #FCD34D; }
  .lead-status--gesloten { background: rgba(52,211,153,0.15);  color: #6EE7B7; }

  @media (max-width: 640px) {
    .stats-row { grid-template-columns: 1fr; }
  }
</style>

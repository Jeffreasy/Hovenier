---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const { getToken } = Astro.locals.auth()
const clerkToken = await getToken({ template: 'convex' }) ?? ''
const { id } = Astro.params
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  <title>Lead detail | Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/portal" class="portal-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Terug naar dashboard
      </a>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container">
      <div id="lead-detail" class="lead-detail">
        <div class="loading-state">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
          Lead laden...
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ convexUrl, clerkToken, id }}>
    async function loadLead() {
      const container = document.getElementById('lead-detail')
      if (!container) return

      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({
            path: 'leads:getLeadById',
            args: { id },
            format: 'json',
          }),
        })
        const { value: lead } = await res.json()

        if (!lead) {
          container.innerHTML = `<div class="error-state"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> Lead niet gevonden of geen toegang.</div>`
          return
        }

        container.innerHTML = `
          <div class="lead-header">
            <div>
              <h1 class="lead-naam">${lead.naam}</h1>
              <span class="lead-status lead-status--${lead.status}">${lead.status}</span>
            </div>
          </div>

          <div class="detail-grid">
            <section class="detail-card">
              <h2>Contactgegevens</h2>
              <dl class="detail-list">
                <div><dt>Naam</dt><dd>${lead.naam}</dd></div>
                <div><dt>E-mail</dt><dd><a href="mailto:${lead.email}">${lead.email}</a></dd></div>
                <div><dt>Telefoon</dt><dd><a href="tel:${lead.telefoon}">${lead.telefoon}</a></dd></div>
                <div><dt>Postcode</dt><dd>${lead.postcode}</dd></div>
              </dl>
            </section>

            <section class="detail-card">
              <h2>Tuinproject</h2>
              <dl class="detail-list">
                <div><dt>Dienst</dt><dd>${lead.dienst}</dd></div>
                <div><dt>Tuinoppervlak</dt><dd>${lead.m2} m²</dd></div>
                <div><dt>Budget</dt><dd>${lead.budget}</dd></div>
                <div><dt>Wanneer</dt><dd>${lead.timing}</dd></div>
              </dl>
            </section>
          </div>

          <section class="detail-card status-card">
            <h2>Status bijwerken</h2>
            <div class="status-buttons">
              ${['nieuw', 'contact', 'gesloten'].map(s => `
                <button
                  class="status-btn ${lead.status === s ? 'status-btn--active' : ''}"
                  data-status="${s}"
                  onclick="updateStatus('${lead._id}', '${s}')"
                >${s}</button>
              `).join('')}
            </div>
            ${lead.notities ? `<p class="notities">${lead.notities}</p>` : ''}
          </section>
        `
      } catch (err) {
        container.innerHTML = `<div class="error-state"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Laden mislukt.</div>`
      }
    }

    async function updateStatus(leadId, status) {
      try {
        await fetch(`${convexUrl}/api/mutation`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({
            path: 'leads:updateLeadStatus',
            args: { id: leadId, status },
            format: 'json',
          }),
        })
        loadLead()
      } catch {
        alert('Status bijwerken mislukt, probeer opnieuw.')
      }
    }

    loadLead()
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #f8fafc;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .portal-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: #008d51;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .portal-back:hover { opacity: 0.75; text-decoration: none; }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 900px; margin: 0 auto; }

  /* ── States ── */
  .loading-state, .error-state {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    padding: 3rem;
    color: #64748b;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }

  /* ── Lead header ── */
  .lead-header { margin-bottom: 1.5rem; }

  .lead-naam {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #282d31;
  }

  /* ── Detail grid ── */
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .detail-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.15s;
  }

  .detail-card h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: 700;
    color: #008d51;
    margin-bottom: 1rem;
  }

  .detail-list { display: flex; flex-direction: column; gap: 0.625rem; }
  .detail-list > div { display: flex; gap: 0.5rem; font-size: 0.9rem; }
  .detail-list dt { color: #94a3b8; min-width: 90px; flex-shrink: 0; }
  .detail-list dd { font-weight: 500; color: #282d31; }
  .detail-list a { color: #008d51; font-weight: 600; text-decoration: none; }
  .detail-list a:hover { text-decoration: underline; }

  /* ── Status card ── */
  .status-card { margin-top: 0; }
  .status-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .status-btn {
    padding: 0.5rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #ffffff;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: capitalize;
    color: #64748b;
    transition: border-color 0.15s, background-color 0.15s, color 0.15s;
  }

  .status-btn:hover {
    border-color: #cbd5e1;
    color: #282d31;
    background: #f8fafc;
  }

  .status-btn--active {
    border-color: #008d51;
    background: rgba(0,141,81,0.08);
    color: #008d51;
  }

  /* ── Status badges ── */
  .lead-status {
    display: inline-flex;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .lead-status--nieuw    { background: rgba(59,130,246,0.10);  color: #2563eb; }
  .lead-status--contact  { background: rgba(245,158,11,0.10);  color: #d97706; }
  .lead-status--gesloten { background: rgba(16,185,129,0.10);  color: #059669; }

  /* ── Notities ── */
  .notities {
    margin-top: 1rem;
    padding: 0.75rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .detail-grid { grid-template-columns: 1fr; }
  }
</style>

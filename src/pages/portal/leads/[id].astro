---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const user = (Astro.locals as Record<string, unknown> & { auth?: () => { userId?: string } }).auth?.()
const clerkId = user?.userId ?? ''
const { id } = Astro.params
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Lead detail — Hovenier Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/portal" class="portal-back">← Terug naar dashboard</a>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container">
      <div id="lead-detail" class="lead-detail">
        <div class="loading-state">⏳ Lead laden…</div>
      </div>
    </div>
  </main>

  <script define:vars={{ convexUrl, clerkId, id }}>
    async function loadLead() {
      const container = document.getElementById('lead-detail')
      if (!container) return

      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            path: 'leads:getLeadById',
            args: { id, clerkId },
            format: 'json',
          }),
        })
        const { value: lead } = await res.json()

        if (!lead) {
          container.innerHTML = `<div class="error-state">❌ Lead niet gevonden of geen toegang.</div>`
          return
        }

        container.innerHTML = `
          <div class="lead-header">
            <div>
              <h1 class="lead-naam">${lead.naam}</h1>
              <span class="lead-status lead-status--${lead.status}">${lead.status}</span>
            </div>
          </div>

          <div class="detail-grid">
            <section class="detail-card">
              <h2>Contactgegevens</h2>
              <dl class="detail-list">
                <div><dt>Naam</dt><dd>${lead.naam}</dd></div>
                <div><dt>E-mail</dt><dd><a href="mailto:${lead.email}">${lead.email}</a></dd></div>
                <div><dt>Telefoon</dt><dd><a href="tel:${lead.telefoon}">${lead.telefoon}</a></dd></div>
                <div><dt>Postcode</dt><dd>${lead.postcode}</dd></div>
              </dl>
            </section>

            <section class="detail-card">
              <h2>Tuinproject</h2>
              <dl class="detail-list">
                <div><dt>Dienst</dt><dd>${lead.dienst}</dd></div>
                <div><dt>Tuinoppervlak</dt><dd>${lead.m2} m²</dd></div>
                <div><dt>Budget</dt><dd>${lead.budget}</dd></div>
                <div><dt>Wanneer</dt><dd>${lead.timing}</dd></div>
              </dl>
            </section>
          </div>

          <section class="detail-card status-card">
            <h2>Status bijwerken</h2>
            <div class="status-buttons">
              ${['nieuw', 'contact', 'gesloten'].map(s => `
                <button
                  class="status-btn ${lead.status === s ? 'status-btn--active' : ''}"
                  data-status="${s}"
                  onclick="updateStatus('${lead._id}', '${s}')"
                >${s}</button>
              `).join('')}
            </div>
            ${lead.notities ? `<p class="notities">${lead.notities}</p>` : ''}
          </section>
        `
      } catch (err) {
        container.innerHTML = `<div class="error-state">⚠️ Laden mislukt.</div>`
      }
    }

    async function updateStatus(leadId, status) {
      try {
        await fetch(`${convexUrl}/api/mutation`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            path: 'leads:updateLeadStatus',
            args: { id: leadId, clerkId, status },
            format: 'json',
          }),
        })
        // Reload UI
        loadLead()
      } catch(err) {
        alert('Status bijwerken mislukt, probeer opnieuw.')
      }
    }

    loadLead()
  </script>

</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body.portal-body { min-height: 100vh; background: #F5F3EF; font-family: 'Inter', sans-serif; }

  .portal-header {
    background: white;
    border-bottom: 1px solid #E5E5E5;
    position: sticky; top: 0; z-index: 50;
  }
  .portal-header-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 1.5rem;
    height: 60px; display: flex; align-items: center; justify-content: space-between;
  }
  .portal-back {
    font-size: 0.875rem; color: #5B7553; font-weight: 600; text-decoration: none;
  }
  .portal-back:hover { text-decoration: underline; }

  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 900px; margin: 0 auto; }

  .loading-state, .error-state {
    text-align: center; padding: 3rem; color: #6B7280;
    background: white; border-radius: 12px; border: 1px solid #E5E5E5;
  }

  /* Lead detail */
  .lead-header { margin-bottom: 1.5rem; }
  .lead-naam {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .detail-card {
    background: white;
    border: 1px solid #E5E5E5;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .detail-card h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6B7280;
    margin-bottom: 1rem;
  }
  .detail-list { display: flex; flex-direction: column; gap: 0.625rem; }
  .detail-list > div { display: flex; gap: 0.5rem; font-size: 0.9rem; }
  .detail-list dt { color: #6B7280; min-width: 90px; flex-shrink: 0; }
  .detail-list dd { font-weight: 500; }
  .detail-list a { color: #5B7553; }

  .status-card { margin-top: 0; }
  .status-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .status-btn {
    padding: 0.5rem 1rem;
    border: 2px solid #E5E5E5;
    border-radius: 8px;
    background: white;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: capitalize;
    transition: all 0.15s;
  }
  .status-btn:hover { border-color: #5B7553; }
  .status-btn--active { border-color: #5B7553; background: #E8F0E4; color: #3D5438; }

  .lead-status {
    display: inline-flex; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem; border-radius: 99px;
  }
  .lead-status--nieuw    { background: #DBEAFE; color: #1D4ED8; }
  .lead-status--contact  { background: #FEF3C7; color: #D97706; }
  .lead-status--gesloten { background: #D1FAE5; color: #065F46; }

  .notities {
    margin-top: 1rem; padding: 0.75rem; background: #F5F3EF;
    border-radius: 8px; font-size: 0.875rem; color: #4A4A4A;
  }

  @media (max-width: 640px) {
    .detail-grid { grid-template-columns: 1fr; }
  }
</style>

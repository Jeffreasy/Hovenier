---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const { getToken } = Astro.locals.auth()
const clerkToken = await getToken({ template: 'convex' }) ?? ''
const { id } = Astro.params
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Lead detail | Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/portal" class="portal-back">← Terug naar dashboard</a>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container">
      <div id="lead-detail" class="lead-detail">
        <div class="loading-state">⏳ Lead laden…</div>
      </div>
    </div>
  </main>

  <script define:vars={{ convexUrl, clerkToken, id }}>
    async function loadLead() {
      const container = document.getElementById('lead-detail')
      if (!container) return

      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({
            path: 'leads:getLeadById',
            args: { id },
            format: 'json',
          }),
        })
        const { value: lead } = await res.json()

        if (!lead) {
          container.innerHTML = `<div class="error-state">❌ Lead niet gevonden of geen toegang.</div>`
          return
        }

        container.innerHTML = `
          <div class="lead-header">
            <div>
              <h1 class="lead-naam">${lead.naam}</h1>
              <span class="lead-status lead-status--${lead.status}">${lead.status}</span>
            </div>
          </div>

          <div class="detail-grid">
            <section class="detail-card">
              <h2>Contactgegevens</h2>
              <dl class="detail-list">
                <div><dt>Naam</dt><dd>${lead.naam}</dd></div>
                <div><dt>E-mail</dt><dd><a href="mailto:${lead.email}">${lead.email}</a></dd></div>
                <div><dt>Telefoon</dt><dd><a href="tel:${lead.telefoon}">${lead.telefoon}</a></dd></div>
                <div><dt>Postcode</dt><dd>${lead.postcode}</dd></div>
              </dl>
            </section>

            <section class="detail-card">
              <h2>Tuinproject</h2>
              <dl class="detail-list">
                <div><dt>Dienst</dt><dd>${lead.dienst}</dd></div>
                <div><dt>Tuinoppervlak</dt><dd>${lead.m2} m²</dd></div>
                <div><dt>Budget</dt><dd>${lead.budget}</dd></div>
                <div><dt>Wanneer</dt><dd>${lead.timing}</dd></div>
              </dl>
            </section>
          </div>

          <section class="detail-card status-card">
            <h2>Status bijwerken</h2>
            <div class="status-buttons">
              ${['nieuw', 'contact', 'gesloten'].map(s => `
                <button
                  class="status-btn ${lead.status === s ? 'status-btn--active' : ''}"
                  data-status="${s}"
                  onclick="updateStatus('${lead._id}', '${s}')"
                >${s}</button>
              `).join('')}
            </div>
            ${lead.notities ? `<p class="notities">${lead.notities}</p>` : ''}
          </section>
        `
      } catch (err) {
        container.innerHTML = `<div class="error-state">⚠️ Laden mislukt.</div>`
      }
    }

    async function updateStatus(leadId, status) {
      try {
        await fetch(`${convexUrl}/api/mutation`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({
            path: 'leads:updateLeadStatus',
            args: { id: leadId, status },
            format: 'json',
          }),
        })
        loadLead()
      } catch {
        alert('Status bijwerken mislukt, probeer opnieuw.')
      }
    }

    loadLead()
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #EDF2EC;
    background:
      radial-gradient(ellipse 80% 60% at 20% -10%, rgba(70,110,60,0.15) 0%, transparent 60%),
      #0D1F12;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: rgba(13,31,18,0.72);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .portal-back {
    font-size: 0.875rem;
    color: var(--color-secondary, #C4A96A);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .portal-back:hover { opacity: 0.75; text-decoration: none; }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 900px; margin: 0 auto; }

  /* ── States ── */
  .loading-state, .error-state {
    text-align: center;
    padding: 3rem;
    color: rgba(237,242,236,0.40);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
  }

  /* ── Lead header ── */
  .lead-header { margin-bottom: 1.5rem; }

  .lead-naam {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #EDF2EC;
  }

  /* ── Detail grid ── */
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .detail-card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.15s;
  }

  .detail-card h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: 700;
    color: rgba(196,169,106,0.60);
    margin-bottom: 1rem;
  }

  .detail-list { display: flex; flex-direction: column; gap: 0.625rem; }
  .detail-list > div { display: flex; gap: 0.5rem; font-size: 0.9rem; }
  .detail-list dt { color: rgba(237,242,236,0.40); min-width: 90px; flex-shrink: 0; }
  .detail-list dd { font-weight: 500; color: rgba(237,242,236,0.85); }
  .detail-list a { color: #C4A96A; text-decoration: none; }
  .detail-list a:hover { text-decoration: underline; }

  /* ── Status card ── */
  .status-card { margin-top: 0; }
  .status-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .status-btn {
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 8px;
    background: rgba(255,255,255,0.04);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: capitalize;
    color: rgba(237,242,236,0.55);
    transition: border-color 0.15s ease-out, background-color 0.15s ease-out, color 0.15s ease-out;
  }

  .status-btn:hover {
    border-color: rgba(196,169,106,0.35);
    color: rgba(237,242,236,0.85);
    background: rgba(255,255,255,0.07);
  }

  .status-btn--active {
    border-color: rgba(110,158,101,0.45);
    background: rgba(110,158,101,0.12);
    color: #EDF2EC;
  }

  /* ── Status badges ── */
  .lead-status {
    display: inline-flex;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .lead-status--nieuw    { background: rgba(59,130,246,0.15);  color: #93C5FD; }
  .lead-status--contact  { background: rgba(251,191,36,0.15);  color: #FCD34D; }
  .lead-status--gesloten { background: rgba(52,211,153,0.15);  color: #6EE7B7; }

  /* ── Notities ── */
  .notities {
    margin-top: 1rem;
    padding: 0.75rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    font-size: 0.875rem;
    color: rgba(237,242,236,0.55);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .detail-grid { grid-template-columns: 1fr; }
  }
</style>

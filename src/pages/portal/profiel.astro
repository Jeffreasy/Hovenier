---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const { getToken } = Astro.locals.auth()
const clerkToken = await getToken({ template: 'convex' }) ?? ''
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  <title>Mijn profiel | Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/" class="portal-logo">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#008d51" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-7.5 8-13-2 1-3.5 1-5.5 0C10 8.5 8 11 7 14c-1.5 3-2 5-2 6"/><path d="M12 20c-2-2.5-3-5-3-8 2 .5 3.5 1 5 .5"/></svg>
        <span>TuinHub</span>
      </a>
      <nav class="portal-nav">
        <a href="/portal" class="portal-nav-link">Dashboard</a>
        <a href="/portal/profiel" class="portal-nav-link portal-nav-link--active">Mijn profiel</a>
      </nav>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container">

      <div class="page-header">
        <h1>Mijn profiel</h1>
        <p class="page-sub">Beheer jouw bedrijfsgegevens en werkgebied.</p>
      </div>

      <form id="profiel-form" class="profiel-card">
        <div class="form-section">
          <h2>Bedrijfsgegevens</h2>
          <div class="field-grid">
            <div class="field">
              <label for="naam">Bedrijfsnaam *</label>
              <input id="naam" name="naam" type="text" placeholder="Jansen Groenvoorziening" required />
            </div>
            <div class="field">
              <label for="email">E-mailadres *</label>
              <input id="email" name="email" type="email" placeholder="info@jansenhovenier.nl" required />
            </div>
            <div class="field">
              <label for="telefoon">Telefoonnummer</label>
              <input id="telefoon" name="telefoon" type="tel" placeholder="06 12 34 56 78" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h2>Werkgebied</h2>
          <p class="hint">Voer de eerste 2 cijfers in van de postcodes in jouw werkgebied, komma-gescheiden.<br/>Voorbeeld: <code>10, 11, 12, 20</code> voor Amsterdam en omgeving.</p>
          <div class="field">
            <label for="regio">Postcodegebieden *</label>
            <input id="regio" name="regio" type="text" placeholder="10, 11, 12, 20" required />
          </div>
        </div>

        <div class="form-section">
          <h2>Specialisaties</h2>
          <div class="specialisaties-grid" id="specialisaties-grid">
            {['tuinaanleg', 'onderhoud', 'bestrating', 'beplanting', 'schutting', 'overig'].map((s) => (
              <label class="spec-option">
                <input type="checkbox" name="specialisaties" value={s} />
                <span>{s.charAt(0).toUpperCase() + s.slice(1)}</span>
              </label>
            ))}
          </div>
        </div>

        <div id="form-feedback" class="feedback" hidden></div>

        <div class="form-actions">
          <button type="submit" class="save-btn">Opslaan</button>
        </div>
      </form>

    </div>
  </main>

  <script define:vars={{ convexUrl, clerkToken }}>
    const form = document.getElementById('profiel-form')
    const feedback = document.getElementById('form-feedback')

    async function loadProfiel() {
      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({ path: 'hoveniers:getMe', args: {}, format: 'json' }),
        })
        const { value: profiel } = await res.json()
        if (!profiel) return

        form.naam.value     = profiel.naam     ?? ''
        form.email.value    = profiel.email    ?? ''
        form.telefoon.value = profiel.telefoon ?? ''
        form.regio.value    = (profiel.regio   ?? []).join(', ')

        form.querySelectorAll('input[name="specialisaties"]').forEach((cb) => {
          cb.checked = (profiel.specialisaties ?? []).includes(cb.value)
        })
      } catch {}
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const btn = form.querySelector('.save-btn')
      btn.textContent = 'Opslaan...'
      btn.disabled = true

      const regio = form.regio.value.split(',').map(s => s.trim()).filter(Boolean)
      const specialisaties = [...form.querySelectorAll('input[name="specialisaties"]:checked')].map(cb => cb.value)

      try {
        const res = await fetch(`${convexUrl}/api/mutation`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${clerkToken}`,
          },
          body: JSON.stringify({
            path: 'hoveniers:upsertHovenier',
            args: { naam: form.naam.value, email: form.email.value, telefoon: form.telefoon.value || undefined, regio, specialisaties },
            format: 'json',
          }),
        })
        if (!res.ok) throw new Error()
        feedback.textContent = 'Profiel opgeslagen!'
        feedback.className = 'feedback feedback--success'
        feedback.hidden = false
      } catch {
        feedback.textContent = 'Opslaan mislukt, probeer opnieuw.'
        feedback.className = 'feedback feedback--error'
        feedback.hidden = false
      } finally {
        btn.textContent = 'Opslaan'
        btn.disabled = false
        setTimeout(() => { feedback.hidden = true }, 4000)
      }
    })

    loadProfiel()
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #f8fafc;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .portal-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #282d31;
    text-decoration: none;
    flex-shrink: 0;
  }

  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }

  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748b;
    text-decoration: none;
    transition: all 0.15s;
  }

  .portal-nav-link:hover { background: #f1f5f9; color: #282d31; }

  .portal-nav-link--active {
    background: rgba(0,141,81,0.08);
    color: #008d51;
    font-weight: 600;
  }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 720px; margin: 0 auto; }

  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #282d31; }
  .page-sub { margin-top: 0.375rem; color: #64748b; }

  /* ── Profile form card ── */
  .profiel-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
  }

  .form-section {
    padding: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .form-section:last-of-type { border-bottom: none; }

  .form-section h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: 700;
    color: #008d51;
    margin-bottom: 1rem;
  }

  .hint {
    font-size: 0.8rem;
    color: #94a3b8;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .hint code {
    background: #f1f5f9;
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
    color: #475569;
  }

  .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }

  .field label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #475569;
    letter-spacing: 0.02em;
  }

  .field input {
    padding: 0.65rem 0.875rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #ffffff;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .field input::placeholder { color: #cbd5e1; }
  .field input:focus { outline: none; border-color: #008d51; box-shadow: 0 0 0 3px rgba(0,141,81,0.10); }

  /* ── Specialisaties ── */
  .specialisaties-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.625rem; }

  .spec-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748b;
    transition: all 0.15s;
  }

  .spec-option:has(input:checked) {
    border-color: #008d51;
    background: rgba(0,141,81,0.06);
    color: #008d51;
    font-weight: 600;
  }

  .spec-option input { display: none; }

  /* ── Feedback ── */
  .feedback {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    margin: 0 1.5rem;
  }

  .feedback--success { background: rgba(16,185,129,0.08); color: #059669; border: 1px solid rgba(16,185,129,0.20); }
  .feedback--error   { background: rgba(220,38,38,0.08); color: #dc2626; border: 1px solid rgba(220,38,38,0.20); }

  /* ── Actions ── */
  .form-actions { padding: 1.5rem; border-top: 1px solid #e2e8f0; }

  .save-btn {
    padding: 0.75rem 2rem;
    background: #008d51;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }

  .save-btn:hover:not(:disabled) {
    background: #007a46;
  }

  .save-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  @media (max-width: 640px) {
    .field-grid { grid-template-columns: 1fr; }
    .specialisaties-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

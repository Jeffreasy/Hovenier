---
export const prerender = false
import { UserButton } from '@clerk/astro/components'

const { userId: clerkId } = Astro.locals.auth()
const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Mijn profiel — Hovenier Portal</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="portal-body">

  <header class="portal-header">
    <div class="portal-header-inner">
      <a href="/" class="portal-logo">🌿 TuinHub</a>
      <nav class="portal-nav">
        <a href="/portal" class="portal-nav-link">Dashboard</a>
        <a href="/portal/profiel" class="portal-nav-link portal-nav-link--active">Mijn profiel</a>
      </nav>
      <div class="portal-user">
        <UserButton />
      </div>
    </div>
  </header>

  <main class="portal-main">
    <div class="portal-container">

      <div class="page-header">
        <h1>Mijn profiel</h1>
        <p class="page-sub">Beheer jouw bedrijfsgegevens en werkgebied.</p>
      </div>

      <form id="profiel-form" class="profiel-card">
        <div class="form-section">
          <h2>Bedrijfsgegevens</h2>
          <div class="field-grid">
            <div class="field">
              <label for="naam">Bedrijfsnaam *</label>
              <input id="naam" name="naam" type="text" placeholder="Jansen Groenvoorziening" required />
            </div>
            <div class="field">
              <label for="email">E-mailadres *</label>
              <input id="email" name="email" type="email" placeholder="info@jansenhovenier.nl" required />
            </div>
            <div class="field">
              <label for="telefoon">Telefoonnummer</label>
              <input id="telefoon" name="telefoon" type="tel" placeholder="06 12 34 56 78" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h2>Werkgebied</h2>
          <p class="hint">Voer de eerste 2 cijfers in van de postcodes in jouw werkgebied, komma-gescheiden.<br/>Voorbeeld: <code>10, 11, 12, 20</code> voor Amsterdam en omgeving.</p>
          <div class="field">
            <label for="regio">Postcodegebieden *</label>
            <input id="regio" name="regio" type="text" placeholder="10, 11, 12, 20" required />
          </div>
        </div>

        <div class="form-section">
          <h2>Specialisaties</h2>
          <div class="specialisaties-grid" id="specialisaties-grid">
            {['tuinaanleg', 'onderhoud', 'bestrating', 'beplanting', 'schutting', 'overig'].map((s) => (
              <label class="spec-option">
                <input type="checkbox" name="specialisaties" value={s} />
                <span>{s.charAt(0).toUpperCase() + s.slice(1)}</span>
              </label>
            ))}
          </div>
        </div>

        <div id="form-feedback" class="feedback" hidden></div>

        <div class="form-actions">
          <button type="submit" class="save-btn">Opslaan</button>
        </div>
      </form>

    </div>
  </main>

  <script define:vars={{ convexUrl, clerkId }}>
    const form = document.getElementById('profiel-form')
    const feedback = document.getElementById('form-feedback')

    async function loadProfiel() {
      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path: 'hoveniers:getMe', args: { clerkId }, format: 'json' }),
        })
        const { value: profiel } = await res.json()
        if (!profiel) return

        form.naam.value     = profiel.naam     ?? ''
        form.email.value    = profiel.email    ?? ''
        form.telefoon.value = profiel.telefoon ?? ''
        form.regio.value    = (profiel.regio   ?? []).join(', ')

        form.querySelectorAll('input[name="specialisaties"]').forEach((cb) => {
          cb.checked = (profiel.specialisaties ?? []).includes(cb.value)
        })
      } catch {}
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const btn = form.querySelector('.save-btn')
      btn.textContent = 'Opslaan…'
      btn.disabled = true

      const regio = form.regio.value.split(',').map(s => s.trim()).filter(Boolean)
      const specialisaties = [...form.querySelectorAll('input[name="specialisaties"]:checked')].map(cb => cb.value)

      try {
        const res = await fetch(`${convexUrl}/api/mutation`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            path: 'hoveniers:upsertHovenier',
            args: { clerkId, naam: form.naam.value, email: form.email.value, telefoon: form.telefoon.value || undefined, regio, specialisaties },
            format: 'json',
          }),
        })
        if (!res.ok) throw new Error()
        feedback.textContent = '✅ Profiel opgeslagen!'
        feedback.className = 'feedback feedback--success'
        feedback.hidden = false
      } catch {
        feedback.textContent = '❌ Opslaan mislukt, probeer opnieuw.'
        feedback.className = 'feedback feedback--error'
        feedback.hidden = false
      } finally {
        btn.textContent = 'Opslaan'
        btn.disabled = false
        setTimeout(() => { feedback.hidden = true }, 4000)
      }
    })

    loadProfiel()
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.portal-body {
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    color: #EDF2EC;
    background:
      radial-gradient(ellipse 80% 60% at 20% -10%, rgba(70,110,60,0.15) 0%, transparent 60%),
      #0D1F12;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .portal-header {
    background: rgba(13,31,18,0.72);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .portal-header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .portal-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #EDF2EC;
    text-decoration: none;
    flex-shrink: 0;
  }

  .portal-nav { display: flex; gap: 0.25rem; margin-left: 1rem; }

  .portal-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(237,242,236,0.55);
    text-decoration: none;
    transition: all 0.15s;
  }

  .portal-nav-link:hover { background: rgba(255,255,255,0.07); color: #EDF2EC; }

  .portal-nav-link--active {
    background: rgba(110,158,101,0.15);
    color: #EDF2EC;
    font-weight: 600;
  }

  .portal-user { margin-left: auto; }

  /* ── Main ── */
  .portal-main { padding: 2.5rem 1.5rem; }
  .portal-container { max-width: 720px; margin: 0 auto; }

  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #EDF2EC; }
  .page-sub { margin-top: 0.375rem; color: rgba(237,242,236,0.45); }

  /* ── Profile form card ── */
  .profiel-card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 14px;
    overflow: hidden;
  }

  .form-section {
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .form-section:last-of-type { border-bottom: none; }

  .form-section h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: 700;
    color: rgba(196,169,106,0.65);
    margin-bottom: 1rem;
  }

  .hint {
    font-size: 0.8rem;
    color: rgba(237,242,236,0.38);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .hint code {
    background: rgba(255,255,255,0.08);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
    color: rgba(237,242,236,0.65);
  }

  .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }

  .field label {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(237,242,236,0.55);
    letter-spacing: 0.02em;
  }

  .field input {
    padding: 0.65rem 0.875rem;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: 'Inter', sans-serif;
    color: #EDF2EC;
    background: rgba(255,255,255,0.05);
    transition: border-color 0.15s, background 0.15s;
  }

  .field input::placeholder { color: rgba(237,242,236,0.22); }
  .field input:focus { outline: none; border-color: rgba(196,169,106,0.40); background: rgba(255,255,255,0.09); }

  /* ── Specialisaties ── */
  .specialisaties-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.625rem; }

  .spec-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(237,242,236,0.60);
    transition: all 0.15s;
  }

  .spec-option:has(input:checked) {
    border-color: rgba(110,158,101,0.45);
    background: rgba(110,158,101,0.12);
    color: #EDF2EC;
  }

  .spec-option input { display: none; }

  /* ── Feedback ── */
  .feedback {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    margin: 0 1.5rem;
  }

  .feedback--success { background: rgba(52,211,153,0.12); color: #34D399; border: 1px solid rgba(52,211,153,0.20); }
  .feedback--error   { background: rgba(248,113,113,0.12); color: #F87171; border: 1px solid rgba(248,113,113,0.20); }

  /* ── Actions ── */
  .form-actions { padding: 1.5rem; border-top: 1px solid rgba(255,255,255,0.07); }

  .save-btn {
    padding: 0.75rem 2rem;
    background: #C4A96A;
    color: #1C1400;
    border: none;
    border-radius: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(196,169,106,0.25);
    transition: all 0.15s;
  }

  .save-btn:hover:not(:disabled) {
    background: #A88B4A;
    box-shadow: 0 4px 20px rgba(196,169,106,0.35);
    transform: translateY(-1px);
  }

  .save-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  @media (max-width: 640px) {
    .field-grid { grid-template-columns: 1fr; }
    .specialisaties-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

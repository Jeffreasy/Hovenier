---
export const prerender = false
import PortalLayout from '../../layouts/PortalLayout.astro'


const convexUrl = import.meta.env.PUBLIC_CONVEX_URL ?? ''
const userId = Astro.locals.user?.id ?? ''
---

<PortalLayout title="Mijn profiel" activeNav="profiel" maxWidth="720px">

  <div class="page-header">
    <h1>Mijn bedrijf</h1>
    <p class="page-sub">Koppel je account aan je hoveniersbedrijf.</p>
  </div>

  <!-- State: Loading -->
  <div id="state-loading" class="state-card">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    Profiel laden...
  </div>

  <!-- State: Claimed (bedrijf gevonden) -->
  <div id="state-claimed" class="profiel-card" style="display:none;">
    <div class="claimed-header">
      <div class="claimed-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Geclaimd
      </div>
      <h2 id="claimed-naam"></h2>
      <p id="claimed-meta" class="claimed-meta"></p>
    </div>
    <div class="claimed-grid" id="claimed-details"></div>
  </div>

  <!-- State: Unclaimed (zoek je bedrijf) -->
  <div id="state-unclaimed" style="display:none;">
    <div class="search-card">
      <h2>Zoek jouw bedrijf</h2>
      <p class="search-hint">Zoek op bedrijfsnaam om je listing te claimen. Je profiel wordt automatisch gekoppeld aan de bestaande bedrijfsdata.</p>
      <div class="search-input-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="search-input" type="text" placeholder="Bijv. Jansen Groenvoorziening" autocomplete="off" spellcheck="false" />
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
  </div>

  <!-- Feedback -->
  <div id="claim-feedback" class="feedback" hidden></div>

  <script define:vars={{ convexUrl, userId }}>
    function esc(str) {
      const div = document.createElement('div')
      div.textContent = String(str ?? '')
      return div.innerHTML
    }

    let debounceTimer = null

    async function loadMyBedrijf() {
      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path: 'bedrijven:getMyBedrijf', args: { userId }, format: 'json' }),
        })

        document.getElementById('state-loading').style.display = 'none'

        if (res.ok) {
          const { value: bedrijf } = await res.json()
          if (bedrijf) {
            showClaimed(bedrijf)
            return
          }
        }

        // Geen bedrijf gevonden of auth-fout → toon zoekformulier
        document.getElementById('state-unclaimed').style.display = 'block'
        setupSearch()
      } catch {
        document.getElementById('state-loading').style.display = 'none'
        document.getElementById('state-unclaimed').style.display = 'block'
        setupSearch()
      }
    }

    function showClaimed(b) {
      document.getElementById('state-claimed').style.display = 'block'
      document.getElementById('state-unclaimed').style.display = 'none'
      document.getElementById('claimed-naam').textContent = b.naam
      document.getElementById('claimed-meta').textContent =
        [b.hoofdCategorie, b.stad, b.provincie].filter(Boolean).join(' · ')

      const details = document.getElementById('claimed-details')
      const rows = []
      if (b.googleScore) rows.push(`<div class="detail-row"><span>Google Score</span><strong>⭐ ${b.googleScore.toFixed(1)}/5 (${b.aantalReviews ?? 0} reviews)</strong></div>`)
      if (b.stad) rows.push(`<div class="detail-row"><span>Stad</span><strong>${esc(b.stad)}</strong></div>`)
      if (b.provincie) rows.push(`<div class="detail-row"><span>Provincie</span><strong>${esc(b.provincie)}</strong></div>`)
      if (b.postcode) rows.push(`<div class="detail-row"><span>Postcode</span><strong>${esc(b.postcode)}</strong></div>`)
      if (b.telefoon) rows.push(`<div class="detail-row"><span>Telefoon</span><strong><a href="tel:${esc(b.telefoon)}">${esc(b.telefoon)}</a></strong></div>`)
      if (b.website) rows.push(`<div class="detail-row"><span>Website</span><strong><a href="${esc(b.website)}" target="_blank" rel="noopener">${esc(b.website.replace(/^https?:\/\//, '').replace(/\/$/, ''))}</a></strong></div>`)
      if (b.categorieen?.length) rows.push(`<div class="detail-row detail-row--full"><span>Categorieën</span><div class="cat-tags">${b.categorieen.map(c => `<span class="cat-tag">${esc(c)}</span>`).join('')}</div></div>`)
      details.innerHTML = rows.join('')
    }

    function setupSearch() {
      const input = document.getElementById('search-input')
      input.addEventListener('input', () => {
        clearTimeout(debounceTimer)
        debounceTimer = setTimeout(() => searchBedrijven(input.value), 300)
      })
    }

    async function searchBedrijven(query) {
      const results = document.getElementById('search-results')
      if (query.trim().length < 2) {
        results.innerHTML = ''
        return
      }

      results.innerHTML = '<div class="search-loading">Zoeken...</div>'

      try {
        const res = await fetch(`${convexUrl}/api/query`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            path: 'bedrijven:searchUnclaimedBedrijven',
            args: { zoekterm: query },
            format: 'json',
          }),
        })
        const { value: bedrijven } = await res.json()

        if (!bedrijven?.length) {
          results.innerHTML = '<div class="search-empty">Geen bedrijven gevonden. Probeer een andere zoekterm.</div>'
          return
        }

        results.innerHTML = bedrijven.map(b => `
          <div class="search-result">
            <div class="search-result-info">
              <strong>${esc(b.naam)}</strong>
              <span>${[b.stad, b.provincie].filter(Boolean).join(' · ')}${b.googleScore ? ` · ⭐ ${b.googleScore.toFixed(1)}` : ''}</span>
            </div>
            <button class="claim-btn" onclick="claimBedrijf('${esc(b._id)}', '${esc(b.naam)}')">
              Dit is mijn bedrijf
            </button>
          </div>
        `).join('')
      } catch {
        results.innerHTML = '<div class="search-empty">Zoeken mislukt. Probeer opnieuw.</div>'
      }
    }

    async function claimBedrijf(id, naam) {
      const feedback = document.getElementById('claim-feedback')

      // Disable all claim buttons
      document.querySelectorAll('.claim-btn').forEach(btn => {
        btn.disabled = true
        btn.textContent = 'Bezig...'
      })

      try {
        const res = await fetch(`${convexUrl}/api/mutation`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            path: 'bedrijven:claimBedrijf',
            args: { bedrijfId: id, userId },
            format: 'json',
          }),
        })

        if (!res.ok) {
          const data = await res.json().catch(() => null)
          throw new Error(data?.error ?? 'Claimen mislukt')
        }

        feedback.textContent = `✅ "${naam}" is nu aan je account gekoppeld!`
        feedback.className = 'feedback feedback--success'
        feedback.hidden = false

        // Reload to show claimed state
        setTimeout(() => location.reload(), 1500)
      } catch (err) {
        feedback.textContent = `❌ ${err.message}`
        feedback.className = 'feedback feedback--error'
        feedback.hidden = false

        document.querySelectorAll('.claim-btn').forEach(btn => {
          btn.disabled = false
          btn.textContent = 'Dit is mijn bedrijf'
        })
      }
    }

    // Make claimBedrijf available globally for onclick handlers
    window.claimBedrijf = claimBedrijf

    loadMyBedrijf()
  </script>

</PortalLayout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #282d31; }
  .page-sub { margin-top: 0.375rem; color: #475569; }

  /* ── States ── */
  .state-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 3rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    color: #475569;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }

  /* ── Claimed state ── */
  .profiel-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
  }

  .claimed-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .claimed-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.2rem 0.625rem;
    border-radius: 99px;
    background: rgba(16,185,129,0.08);
    color: #059669;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .claimed-header h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #282d31;
    margin: 0 0 0.25rem;
  }

  .claimed-meta {
    color: #94a3b8;
    font-size: 0.875rem;
    margin: 0;
  }

  .claimed-grid { padding: 1.5rem 2rem; }

  :global(.detail-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.625rem 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: 0.9rem;
  }

  :global(.detail-row:last-child) { border-bottom: none; }
  :global(.detail-row--full) { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  :global(.detail-row span:first-child) { color: #94a3b8; font-weight: 500; }
  :global(.detail-row strong) { color: #282d31; font-weight: 600; }
  :global(.detail-row a) { color: #008d51; text-decoration: none; }
  :global(.detail-row a:hover) { text-decoration: underline; }

  :global(.cat-tags) { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  :global(.cat-tag) {
    padding: 0.2rem 0.5rem;
    background: rgba(0,141,81,0.06);
    border: 1px solid rgba(0,141,81,0.15);
    border-radius: 6px;
    font-size: 0.75rem;
    color: #008d51;
    font-weight: 500;
  }

  /* ── Search / Unclaimed ── */
  .search-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 2rem;
  }

  .search-card h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: #282d31;
    margin: 0 0 0.375rem;
  }

  .search-hint {
    color: #94a3b8;
    font-size: 0.875rem;
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .search-input-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    pointer-events: none;
  }

  .search-input-wrap input {
    width: 100%;
    padding: 0.875rem 1rem 0.875rem 2.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    color: #282d31;
    background: #ffffff;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }

  .search-input-wrap input:focus {
    outline: none;
    border-color: #008d51;
    box-shadow: 0 0 0 3px rgba(0,141,81,0.10);
  }

  .search-input-wrap input::placeholder { color: #cbd5e1; }

  .search-results {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.search-loading), :global(.search-empty) {
    text-align: center;
    padding: 1.5rem;
    color: #94a3b8;
    font-size: 0.875rem;
  }

  :global(.search-result) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    transition: border-color 0.15s;
  }

  :global(.search-result:hover) { border-color: #cbd5e1; }

  :global(.search-result-info) {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  :global(.search-result-info strong) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    color: #282d31;
    font-size: 0.9375rem;
  }

  :global(.search-result-info span) {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  :global(.claim-btn) {
    padding: 0.5rem 1rem;
    background: #008d51;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }

  :global(.claim-btn:hover:not(:disabled)) { background: #007a46; }
  :global(.claim-btn:disabled) { opacity: 0.5; cursor: not-allowed; }

  /* ── Feedback ── */
  .feedback {
    padding: 0.875rem 1.25rem;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: 1rem;
  }

  .feedback--success { background: rgba(16,185,129,0.08); color: #059669; border: 1px solid rgba(16,185,129,0.20); }
  .feedback--error   { background: rgba(220,38,38,0.08); color: #dc2626; border: 1px solid rgba(220,38,38,0.20); }
</style>

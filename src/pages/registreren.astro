---
export const prerender = false
import RegisterForm from '../islands/RegisterForm'
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  <title>Registreren als hovenier | TuinHub</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

</head>
<body class="auth-body">

  <div class="auth-wrapper">
    <div class="auth-brand">
      <a href="/" class="auth-logo" aria-label="TuinHub homepage">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#008d51" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-7.5 8-13-2 1-3.5 1-5.5 0C10 8.5 8 11 7 14c-1.5 3-2 5-2 6"/><path d="M12 20c-2-2.5-3-5-3-8 2 .5 3.5 1 5 .5"/></svg>
        <span>TuinHub</span>
      </a>
      <p>Registreer jouw hoveniersbedrijf</p>
    </div>
    <RegisterForm client:load />
    <div class="auth-footer-links">
      <p>Al een account? <a href="/inloggen">Inloggen</a></p>
    </div>
  </div>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body.auth-body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
      color: #282d31;
      background: #f8fafc;
      -webkit-font-smoothing: antialiased;
    }

    .auth-wrapper {
      position: relative; z-index: 1;
      display: flex; flex-direction: column; align-items: center; gap: 2rem;
      width: 100%; max-width: 480px;
    }

    .auth-brand { text-align: center; }
    .auth-logo {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 700;
      color: #282d31; text-decoration: none; letter-spacing: -0.01em;
    }
    .auth-brand p { margin-top: 0.375rem; font-size: 0.875rem; color: #475569; }
    .auth-footer-links { text-align: center; font-size: 0.875rem; color: #475569; }
    .auth-footer-links a { color: #008d51; text-decoration: none; font-weight: 600; }
    .auth-footer-links a:hover { text-decoration: underline; }

    /* Shared auth styles inherited from inloggen.astro global styles */
    :global(.auth-card) { width: 100%; background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 2rem; }
    :global(.auth-title) { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.375rem; font-weight: 700; color: #282d31; margin: 0 0 0.25rem; text-align: center; }
    :global(.auth-subtitle) { font-size: 0.875rem; color: #94a3b8; text-align: center; margin: 0 0 1.5rem; }
    :global(.auth-form) { display: flex; flex-direction: column; gap: 1rem; }
    :global(.form-field) { display: flex; flex-direction: column; gap: 0.375rem; }
    :global(.form-field label) { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; color: #64748b; }
    :global(.form-field input) { width: 100%; padding: 0.75rem 1rem; border: 1px solid #e2e8f0; border-radius: 10px; font-size: 0.9375rem; font-family: 'Inter', sans-serif; color: #282d31; background: #fff; transition: border-color 0.15s, box-shadow 0.15s; box-sizing: border-box; }
    :global(.form-field input:focus) { outline: none; border-color: #008d51; box-shadow: 0 0 0 3px rgba(0,141,81,0.10); }
    :global(.form-field input::placeholder) { color: #cbd5e1; }
    :global(.auth-submit) { width: 100%; padding: 0.875rem; background: #008d51; color: #fff; border: none; border-radius: 10px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; cursor: pointer; transition: background 0.15s, transform 0.1s; margin-top: 0.5rem; }
    :global(.auth-submit:hover:not(:disabled)) { background: #007a46; transform: translateY(-1px); }
    :global(.auth-submit:disabled) { opacity: 0.6; cursor: not-allowed; }
    :global(.auth-alert) { padding: 0.75rem 1rem; border-radius: 10px; font-size: 0.8125rem; font-weight: 500; margin-bottom: 0.5rem; }
    :global(.auth-alert--error) { background: rgba(220,38,38,0.06); color: #dc2626; border: 1px solid rgba(220,38,38,0.15); }
    :global(.auth-alert--success) { background: rgba(16,185,129,0.06); color: #059669; border: 1px solid rgba(16,185,129,0.15); }
  </style>
</body>
</html>

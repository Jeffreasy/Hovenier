---
export const prerender = false
import { SignUp } from '@clerk/astro/components'
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#ffffff" />
  <meta name="color-scheme" content="light" />
  <title>Registreren als hovenier | TuinHub</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="auth-body">

  <div class="auth-wrapper">
    <div class="auth-brand">
      <a href="/" class="auth-logo" aria-label="TuinHub homepage">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#008d51" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5 8-7.5 8-13-2 1-3.5 1-5.5 0C10 8.5 8 11 7 14c-1.5 3-2 5-2 6"/><path d="M12 20c-2-2.5-3-5-3-8 2 .5 3.5 1 5 .5"/></svg>
        <span>TuinHub</span>
      </a>
      <p>Registreer jouw hoveniersbedrijf</p>
    </div>
    <SignUp
      signInUrl="/inloggen"
      forceRedirectUrl="/portal"
    />
  </div>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body.auth-body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
      color: #282d31;
      background: #f8fafc;
      -webkit-font-smoothing: antialiased;
    }

    .auth-wrapper {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      width: 100%;
      max-width: 480px;
    }

    .auth-brand { text-align: center; }

    .auth-logo {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: #282d31;
      text-decoration: none;
      letter-spacing: -0.01em;
    }

    .auth-brand p {
      margin-top: 0.375rem;
      font-size: 0.875rem;
      color: #475569;
    }
  </style>
</body>
</html>

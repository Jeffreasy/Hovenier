---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleLayout from '../../layouts/ArticleLayout.astro'
import { getCollection, getEntry } from 'astro:content'
import { getReadingTime } from '../../lib/utils'
import { render } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft)
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)

const readingTime = getReadingTime(post.body ?? '')

const seo = {
  title: post.data.title,
  description: post.data.description,
  ogType: 'article' as const,
  ogImage: post.data.image,
}
---

<ArticleLayout
  {seo}
  title={post.data.title}
  description={post.data.description}
  publishDate={post.data.publishDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
>
  <!-- Table of contents -->
  <nav slot="toc" aria-label="Inhoudsopgave">
    <p class="toc-title">Inhoudsopgave</p>
    <ul class="toc-list">
      {headings.filter(h => h.depth <= 3).map(h => (
        <li class={`toc-item toc-depth-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Reading time -->
  <span slot="reading-time">⏱ {readingTime} min lezen</span>

  <!-- Article body -->
  <Content />
</ArticleLayout>

<style>
  .toc-title {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: rgba(196,169,106,0.60);
    margin: 0 0 0.75rem;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .toc-item a {
    font-size: 0.8125rem;
    color: rgba(237,242,236,0.48);
    text-decoration: none;
    line-height: 1.4;
    transition: color var(--transition-fast);
  }

  .toc-item a:hover { color: rgba(237,242,236,0.85); }

  .toc-depth-3 { padding-left: 1rem; }
</style>

---
interface Props {
  title: string
  description: string
  href: string
  cta: string
  variant?: 'inline' | 'banner'
}

const { title, description, href, cta, variant = 'inline' } = Astro.props
---

<div class={`cta-block cta-block--${variant}`}>
  <div class="cta-block__content">
    <div class="cta-block__icon" aria-hidden="true">
      {variant === 'banner' ? '🌿' : '📊'}
    </div>
    <div>
      <strong class="cta-block__title">{title}</strong>
      <p class="cta-block__description">{description}</p>
    </div>
  </div>
  <a href={href} class="cta-block__button">
    {cta}
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</div>

<style>
  .cta-block {
    border-radius: var(--radius-lg);
    margin: 2rem 0;
  }

  .cta-block--inline {
    background: rgba(110,158,101,0.10);
    border: 1px solid rgba(110,158,101,0.25);
    border-left: 3px solid var(--color-primary);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cta-block--banner {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.12);
    border-top: 2px solid var(--color-secondary);
    padding: 2rem 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.30);
  }

  .cta-block__content { display: flex; align-items: center; gap: 1rem; }
  .cta-block__icon { font-size: 1.75rem; flex-shrink: 0; }

  .cta-block__title {
    display: block;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--color-text-primary);
  }

  .cta-block__description {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .cta-block__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
    background: var(--color-secondary);
    color: #1C1400;
    border: none;
    box-shadow: 0 2px 12px rgba(196,169,106,0.20);
    transition: all var(--transition-base);
    flex-shrink: 0;
  }

  .cta-block__button:hover {
    background: var(--color-secondary-dark);
    box-shadow: 0 4px 20px rgba(196,169,106,0.35);
    transform: translateY(-1px);
    text-decoration: none;
    color: #1C1400;
  }
</style>

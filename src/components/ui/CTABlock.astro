---
interface Props {
  title: string
  description: string
  href: string
  cta: string
  variant?: 'inline' | 'banner'
}

const { title, description, href, cta, variant = 'inline' } = Astro.props
---

<div class={`cta-block cta-block--${variant}`}>
  <div class="cta-block__content">
    <div class="cta-block__icon" aria-hidden="true">
      {variant === 'banner' ? '🌿' : '📊'}
    </div>
    <div>
      <strong class="cta-block__title">{title}</strong>
      <p class="cta-block__description">{description}</p>
    </div>
  </div>
  <a href={href} class="cta-block__button">
    {cta}
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</div>

<style>
  .cta-block {
    border-radius: var(--radius-lg);
    margin: 2rem 0;
  }

  /* Inline variant: in-content CTA */
  .cta-block--inline {
    background-color: var(--color-primary-light);
    border-left: 4px solid var(--color-primary);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* Banner variant: full-width CTA at bottom */
  .cta-block--banner {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    padding: 2rem 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .cta-block__content {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-block__icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .cta-block__title {
    display: block;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .cta-block--banner .cta-block__title { color: white; }
  .cta-block--inline .cta-block__title  { color: var(--color-neutral-900); }

  .cta-block__description {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.85;
  }

  .cta-block__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-base);
    flex-shrink: 0;
  }

  .cta-block--inline .cta-block__button {
    background-color: var(--color-secondary);
    color: var(--color-neutral-900);
    border: 2px solid var(--color-secondary);
  }

  .cta-block--inline .cta-block__button:hover {
    background-color: var(--color-secondary-dark);
    border-color: var(--color-secondary-dark);
    text-decoration: none;
  }

  .cta-block--banner .cta-block__button {
    background-color: var(--color-secondary);
    color: var(--color-neutral-900);
    border: 2px solid var(--color-secondary);
  }

  .cta-block--banner .cta-block__button:hover {
    background-color: white;
    border-color: white;
    text-decoration: none;
  }
</style>

---
interface Props {
  title: string
  description: string
  href: string
  cta: string
  variant?: 'inline' | 'banner'
}

const { title, description, href, cta, variant = 'inline' } = Astro.props
---

<div class={`cta-block cta-block--${variant}`}>
  <div class="cta-block__content">
    <div class="cta-block__icon" aria-hidden="true">
      {variant === 'banner' ? (
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      ) : (
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
      )}
    </div>
    <div>
      <strong class="cta-block__title">{title}</strong>
      <p class="cta-block__description">{description}</p>
    </div>
  </div>
  <a href={href} class="cta-block__button">
    {cta}
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>
</div>

<style>
  .cta-block {
    border-radius: var(--radius-lg);
    margin: 2rem 0;
  }

  .cta-block--inline {
    background: var(--color-primary-50);
    border: 1px solid var(--color-primary-200);
    border-left: 3px solid var(--color-primary-500);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .cta-block--banner {
    background: var(--color-charcoal);
    border: 1px solid var(--color-charcoal);
    padding: 2rem 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .cta-block__content { display: flex; align-items: center; gap: 1rem; }
  .cta-block__icon { flex-shrink: 0; }

  .cta-block--inline .cta-block__icon { color: var(--color-primary-500); }
  .cta-block--banner .cta-block__icon { color: rgba(255,255,255,0.65); }

  .cta-block__title {
    display: block;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .cta-block--inline .cta-block__title { color: var(--color-charcoal); }
  .cta-block--banner .cta-block__title { color: var(--color-white); }

  .cta-block__description {
    margin: 0;
    font-size: 0.875rem;
  }

  .cta-block--inline .cta-block__description { color: var(--color-charcoal-light); }
  .cta-block--banner .cta-block__description { color: rgba(255,255,255,0.65); }

  .cta-block__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-md);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
    background: var(--color-primary-500);
    color: var(--color-white);
    border: none;
    transition: all var(--transition-base);
    flex-shrink: 0;
  }

  .cta-block__button:hover {
    background: var(--color-primary-600);
    transform: translateY(-1px);
    text-decoration: none;
    color: var(--color-white);
  }
</style>

---
interface Props {
  href?: string
  type?: 'button' | 'submit' | 'reset'
  variant?: 'primary' | 'secondary' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  fullWidth?: boolean
  disabled?: boolean
  class?: string
  id?: string
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  disabled = false,
  class: className = '',
  id,
} = Astro.props

const baseStyles = [
  'inline-flex items-center justify-center gap-2',
  'font-heading',
  'transition-all duration-200',
  'cursor-pointer',
  'no-underline',
  'select-none',
  fullWidth ? 'w-full' : '',
].join(' ')

const variantClasses: Record<string, string> = {
  primary:   'btn-primary',
  secondary: 'btn-secondary',
  ghost:     'btn-ghost',
}

const sizeClasses: Record<string, string> = {
  sm: 'btn-sm',
  md: 'btn-md',
  lg: 'btn-lg',
}

const classes = [baseStyles, variantClasses[variant], sizeClasses[size], className]
  .filter(Boolean)
  .join(' ')
---

{href ? (
  <a href={href} class={classes} aria-disabled={disabled} id={id}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} id={id}>
    <slot />
  </button>
)}

<style>
  /* Primary: trustworthy green */
  :global(.btn-primary) {
    background: var(--color-primary-500);
    border: none;
    color: var(--color-white);
    font-weight: 700;
    box-shadow: var(--shadow-sm);
  }
  :global(.btn-primary:hover:not(:disabled)) {
    background: var(--color-primary-600);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: var(--color-white);
  }
  :global(.btn-primary:active) {
    background: var(--color-primary-700);
    box-shadow: var(--shadow-xs);
  }
  :global(.btn-primary:focus-visible) {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-white), 0 0 0 4px var(--color-primary-500);
  }

  /* Secondary: outlined green */
  :global(.btn-secondary) {
    background: transparent;
    border: 1.5px solid var(--color-primary-500);
    color: var(--color-primary-500);
    font-weight: 600;
  }
  :global(.btn-secondary:hover:not(:disabled)) {
    background: var(--color-primary-50);
    border-color: var(--color-primary-600);
    color: var(--color-primary-600);
    text-decoration: none;
  }

  /* Ghost: transparent, subtle */
  :global(.btn-ghost) {
    background: transparent;
    border: none;
    color: var(--color-primary-500);
    font-weight: 600;
  }
  :global(.btn-ghost:hover:not(:disabled)) {
    background: var(--color-primary-50);
    text-decoration: none;
    color: var(--color-primary-600);
  }

  /* Sizes */
  :global(.btn-sm) {
    padding: 0.375rem 0.875rem;
    font-size: 0.875rem;
    border-radius: var(--radius-md);
  }
  :global(.btn-md) {
    padding: 0.625rem 1.25rem;
    font-size: 1rem;
    border-radius: var(--radius-md);
  }
  :global(.btn-lg) {
    padding: 0.875rem 1.875rem;
    font-size: 1.0625rem;
    border-radius: var(--radius-md);
  }

  :global(button:disabled),
  :global(a[aria-disabled="true"]) {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>

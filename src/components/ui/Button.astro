---
interface Props {
  href?: string
  type?: 'button' | 'submit' | 'reset'
  variant?: 'primary' | 'secondary' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  fullWidth?: boolean
  disabled?: boolean
  class?: string
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  disabled = false,
  class: className = '',
} = Astro.props

const baseStyles = [
  'inline-flex items-center justify-center gap-2',
  'font-heading font-semibold',
  'border-2',
  'transition-all duration-200',
  'cursor-pointer',
  'no-underline',
  'select-none',
  fullWidth ? 'w-full' : '',
].join(' ')

const variantClasses: Record<string, string> = {
  primary:   'btn-primary',
  secondary: 'btn-secondary',
  ghost:     'btn-ghost',
}

const sizeClasses: Record<string, string> = {
  sm: 'btn-sm',
  md: 'btn-md',
  lg: 'btn-lg',
}

const classes = [baseStyles, variantClasses[variant], sizeClasses[size], className]
  .filter(Boolean)
  .join(' ')
---

{href ? (
  <a href={href} class={classes} aria-disabled={disabled}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled}>
    <slot />
  </button>
)}

<style>
  /* Primary: warm zand achtergrond, donkere tekst */
  :global(.btn-primary) {
    background-color: var(--color-secondary);
    border-color: var(--color-secondary);
    color: var(--color-neutral-900);
  }
  :global(.btn-primary:hover:not(:disabled)) {
    background-color: var(--color-secondary-dark);
    border-color: var(--color-secondary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  :global(.btn-primary:active) { transform: translateY(0); }

  /* Secondary: groene outline */
  :global(.btn-secondary) {
    background-color: transparent;
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  :global(.btn-secondary:hover:not(:disabled)) {
    background-color: var(--color-primary-light);
    transform: translateY(-1px);
  }

  /* Ghost: geen border */
  :global(.btn-ghost) {
    background-color: transparent;
    border-color: transparent;
    color: var(--color-primary);
  }
  :global(.btn-ghost:hover:not(:disabled)) {
    background-color: var(--color-primary-light);
  }

  /* Sizes */
  :global(.btn-sm) {
    padding: 0.375rem 0.875rem;
    font-size: 0.875rem;
    border-radius: var(--radius-md);
  }
  :global(.btn-md) {
    padding: 0.625rem 1.25rem;
    font-size: 1rem;
    border-radius: var(--radius-md);
  }
  :global(.btn-lg) {
    padding: 0.875rem 1.75rem;
    font-size: 1.0625rem;
    border-radius: var(--radius-md);
  }

  :global(button:disabled),
  :global(a[aria-disabled="true"]) {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>

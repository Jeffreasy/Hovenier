---
interface Props {
  href?: string
  hover?: boolean
  padding?: 'sm' | 'md' | 'lg'
  class?: string
}

const {
  href,
  hover = true,
  padding = 'md',
  class: className = '',
} = Astro.props

const paddingMap = { sm: 'card-p-sm', md: 'card-p-md', lg: 'card-p-lg' }
const classes = ['card', hover ? 'card-hover' : '', paddingMap[padding], className]
  .filter(Boolean)
  .join(' ')
---

{href ? (
  <a href={href} class={classes} style="text-decoration: none; color: inherit;">
    <slot />
  </a>
) : (
  <div class={classes}>
    <slot />
  </div>
)}

<style>
  :global(.card) {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    overflow: hidden;
    color: inherit;
  }

  :global(.card-hover) {
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  :global(.card-hover:hover) {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  :global(.card-p-sm) { padding: 1rem; }
  :global(.card-p-md) { padding: 1.5rem; }
  :global(.card-p-lg) { padding: 2rem; }
</style>

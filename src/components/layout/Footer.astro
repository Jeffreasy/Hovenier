---
import { SITE, NAV_LINKS } from '../../lib/constants'
---

<footer class="site-footer">
  <!-- Divider glow lijn -->
  <div class="footer-glow-line" aria-hidden="true"></div>

  <div class="container footer-grid">
    <!-- Brand column -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span aria-hidden="true">🌿</span>
        <span>{SITE.name}</span>
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>
      <p class="footer-desc">
        Vergelijk hoveniers in jouw buurt. Gratis offertes van lokale professionals.
      </p>
    </div>

    <!-- Navigation -->
    <nav aria-label="Footer navigatie">
      <h3 class="footer-heading">Platform</h3>
      <ul class="footer-list" role="list">
        {NAV_LINKS.map((link) => (
          <li><a href={link.href} class="footer-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Services -->
    <nav aria-label="Diensten">
      <h3 class="footer-heading">Tools</h3>
      <ul class="footer-list" role="list">
        <li><a href="/steden" class="footer-link">Steden overzicht</a></li>
        <li><a href="/tools/tuinkosten-calculator" class="footer-link">Tuinkosten Calculator</a></li>
        <li><a href="/blog" class="footer-link">Tuingids &amp; tips</a></li>
        <li><a href="/faq" class="footer-link">Veelgestelde vragen</a></li>
      </ul>
    </nav>

    <!-- Contact / Legal -->
    <div>
      <h3 class="footer-heading">Contact</h3>
      <ul class="footer-list" role="list">
        <li><a href="/contact" class="footer-link">Contact</a></li>
        <li><a href="/over-ons" class="footer-link">Over ons</a></li>
        <li><a href="/privacybeleid" class="footer-link">Privacybeleid</a></li>
        <li><a href="/algemene-voorwaarden" class="footer-link">Algemene voorwaarden</a></li>
        <li><a href="/inloggen" class="footer-link footer-link--portal">🔐 Hovenier portal</a></li>
      </ul>
      <p class="footer-contact">
        <a href={`mailto:${SITE.email}`} class="footer-link">{SITE.email}</a>
      </p>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copyright">
        © {new Date().getFullYear()} {SITE.name}. Alle rechten voorbehouden.
      </p>
      <p class="footer-disclaimer">
        {SITE.name} bemiddelt tussen particulieren en hoveniers. Wij zijn geen hoveniersbedrijf.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: rgba(8, 18, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    margin-top: 4rem;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .footer-glow-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(196,169,106,0.35), transparent);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: #EDF2EC;
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin: 0 0 0.5rem;
    opacity: 0.85;
  }

  .footer-desc {
    font-size: 0.875rem;
    color: rgba(237,242,236,0.45);
    line-height: 1.6;
    margin: 0;
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-secondary);
    opacity: 0.70;
    margin: 0 0 1rem;
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: rgba(237,242,236,0.50);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: #EDF2EC;
    text-decoration: none;
  }

  .footer-link--portal {
    color: rgba(196,169,106,0.55);
    margin-top: 0.375rem;
  }

  .footer-link--portal:hover {
    color: var(--color-secondary);
  }

  .footer-contact { margin-top: 1rem; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
  }

  .footer-copyright,
  .footer-disclaimer {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(237,242,236,0.28);
  }
</style>

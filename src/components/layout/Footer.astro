        <span class="footer-logo-text">Tuin<span class="footer-logo-accent">Hub</span><span class="footer-logo-nl">.nl</span></span>
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>
      <p class="footer-desc">
        Vergelijk hoveniers in jouw buurt. Gratis offertes van lokale professionals.
      </p>
    </div>

    <!-- Navigation -->
    <nav aria-label="Footer navigatie">
      <h3 class="footer-heading">Platform</h3>
      <ul class="footer-list" role="list">
        {NAV_LINKS.map((link) => (
          <li><a href={link.href} class="footer-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Services -->
    <nav aria-label="Diensten">
      <h3 class="footer-heading">Tools</h3>
      <ul class="footer-list" role="list">
        <li><a href="/steden" class="footer-link">Steden overzicht</a></li>
        <li><a href="/tools/tuinkosten-calculator" class="footer-link">Tuinkosten Calculator</a></li>
        <li><a href="/blog" class="footer-link">Tuingids &amp; tips</a></li>
        <li><a href="/faq" class="footer-link">Veelgestelde vragen</a></li>
      </ul>
    </nav>

    <!-- Project Team -->
    <div>
      <h3 class="footer-heading">Project Team</h3>
      <div class="footer-team-card">
        <p class="footer-team-role">Fullstack Prompt-engineer</p>
        <div class="footer-team-names">
          <span>Jeffrey Lavente</span>
        </div>
      </div>

      <!-- Contact -->
      <div class="footer-contact-block">
        <a href="/contact" class="footer-link">Contact</a>
        <a href={`mailto:${SITE.email}`} class="footer-link">{SITE.email}</a>
        <a href="/inloggen" class="footer-link footer-link--portal">Hovenier portal</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar — LaventeCare branding -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copyright">
        &copy; {new Date().getFullYear()} LaventeCare. All rights reserved.
      </p>
      <p class="footer-powered">
        Powered by <a
          href="https://www.laventecare.nl"
          class="footer-shimmer-link"
        >LaventeCare AuthSystem</a>
      </p>
    </div>
  </div>
</footer>

<style>
  /* ── Footer Container ─────────────────────────────────────────── */
  .site-footer {
    position: relative;
    background: var(--color-canvas-alt);
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
  }

  /* ── Grid Layout ───────────────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr; }
  }

  /* ── Brand Column ──────────────────────────────────────────────── */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-logo:hover { text-decoration: none; }

  .footer-logo-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .footer-logo-text {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-charcoal);
    letter-spacing: -0.025em;
    line-height: 1;
    white-space: nowrap;
  }

  .footer-logo-accent {
    color: var(--color-primary-500);
  }

  .footer-logo-nl {
    font-size: 0.75em;
    font-weight: 600;
    color: var(--color-charcoal-muted);
  }

  .footer-tagline {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-primary-600);
    margin: 0 0 0.5rem;
  }

  .footer-desc {
    font-size: 0.875rem;
    color: var(--color-charcoal-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Navigation ────────────────────────────────────────────────── */
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-charcoal-muted);
    margin: 0 0 1rem;
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-charcoal-light);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-charcoal);
    text-decoration: none;
  }

  .footer-link--portal {
    color: var(--color-primary-600);
    margin-top: 0.375rem;
  }

  .footer-link--portal:hover {
    color: var(--color-primary-500);
  }

  /* ── Project Team Card ─────────────────────────────────────────── */
  .footer-team-card {
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    margin-bottom: 1.25rem;
  }

  .footer-team-role {
    font-size: 0.75rem;
    color: var(--color-charcoal-muted);
    margin: 0 0 0.375rem;
    letter-spacing: 0.02em;
  }

  .footer-team-names {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-charcoal);
  }


  .footer-contact-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0;
  }

  /* ── Bottom Bar — LaventeCare Branding ─────────────────────────── */
  .footer-bottom {
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  @media (min-width: 640px) {
    .footer-bottom-inner {
      flex-direction: row;
    }
  }

  .footer-copyright {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-charcoal-muted);
  }

  .footer-powered {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-charcoal-muted);
  }

  /* ── Shimmer Gradient Link ─────────────────────────────────────── */
  .footer-shimmer-link {
    font-weight: 600;
    background: linear-gradient(
      to right,
      var(--color-primary-500),
      var(--color-primary-300),
      var(--color-primary-500)
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-decoration: none;
    animation: shimmer 3s linear infinite;
    transition: opacity var(--transition-fast);
  }

  .footer-shimmer-link:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  @keyframes shimmer {
    0%   { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-shimmer-link {
      animation: none;
    }
  }
</style>

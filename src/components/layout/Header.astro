          <path d="M788.94 290c6.94 7.56 14.86 18.4 20.68 26.78 32.32 46.73 52.13 100.97 57.53 157.53-2.36-.02-4.9-.17-7.28-.25-1.05 0-2.64.18-2.82-.95-2.47-17.38-5.38-34.47-10-51.42-12.9-47.37-35.62-87.02-65.73-125.38l7.61-6.16-.01-.15Z"/>
        </g>
        <path fill="#1E904A" d="M678.62 275.97c.81.56 1.63 1.11 2.45 1.66 9.48 88.55 11.17 178.29-27.72 260.81-31.59 67.04-88.94 123.9-165.47 132.09-24.9 2.74-50.09.2-73.95-7.42 8.55-23.19 22.66-41.21 45.44-51.76 12.45-5.77 26.67-8.46 40.35-7.95 16.4.6 30.72-1.87 46.42-6.42l-1.2-1.62c-13.36 1.41-28.69.71-42.01-1.21-97.5-14.04-123.03 90.09-122.35 167.83l-29.71-.13c.85-29.28 13.19-73.01 24.67-99.57 15.27-35.3 37.6-72.41 63.59-100.95 5.47-6.01 12.26-13.36 19-17.63 17.58-11.43 38.77-18.49 60.07-16.13 28.85 3.2 53.72 7.26 82.22-4.1l-.35-1.17c-16.02 2.7-35.84 1.38-51.93-1.45-24.63-4.33-38.91-9.89-64.24-4.63 22.68-22.1 52.55-46.38 77.81-65.88 25.17 5.73 58 1.42 81.53-8.57l-.43-.96c-23.1 5.53-48.1 4.07-71.55 2.03 39.15-32.86 65.18-59.89 87.9-105.6l-.6-1.15c-30.36 57.05-79.75 88.24-131.1 124.61.01-34.13 10.8-55.75 34.54-79.61l.37-.37-1-.85c-27.05 24.23-46.75 49.48-48.9 87.7-.09 1.83-.13 3.66-.13 5.49-24.96 18.83-48.12 37.95-68.79 61.49-2.16 2.46-4.61 5.14-6.87 7.49-5.08-35.09-1.56-54.88 17.89-85.44l-.7-1.03c-29.24 31.37-36.55 58.36-31.18 100.34-14.31 15.95-27.31 30.88-39.16 48.89-5.67 8.61-10.73 17.75-15.8 26.73-23.59-37.95-24.57-94.58-9-135.78 2.42-6.4 5.21-13.01 8.22-19.16 11.05-22.57 25.99-43 44.17-60.36 39.04-37.67 79.67-54.35 131.29-68.82 24.07-6.74 47.97-9.9 71.45-18.35 31.13-11.21 50.09-22.97 64.75-53.06Z"/>
      </svg>
      <span class="logo-wordmark">Tuin<span class="logo-wordmark-accent">Hub</span><span class="logo-wordmark-tld">.nl</span></span>
    </a>

    <!-- Desktop navigation -->
    <nav class="header-nav" aria-label="Hoofdnavigatie">
      <ul class="nav-list" role="list">
        {NAV_LINKS.filter(l => l.href !== '/offerte').map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop: Hovenier login -->
    <a href="/inloggen" class="header-login" aria-label="Inloggen als hovenier">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Hovenier inloggen
    </a>

    <!-- Desktop CTA -->
    <a href="/offerte" class="header-cta btn-primary">
      Gratis offerte
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      class="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu openen"
      id="mobile-menu-btn"
      type="button"
    >
      <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="navigation" aria-label="Mobiele navigatie">
    <ul role="list">
      {NAV_LINKS.filter(l => l.href !== '/offerte').map((link) => (
        <li>
          <a href={link.href} class="mobile-link">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/offerte" class="mobile-cta">
          Gratis offerte aanvragen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:inline;vertical-align:middle;margin-left:0.25rem">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </li>
      <li class="mobile-divider" aria-hidden="true"></li>
      <li>
        <a href="/inloggen" class="mobile-login">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Hovenier inloggen
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn    = document.getElementById('mobile-menu-btn')
  const menu   = document.getElementById('mobile-menu')
  const iconMenu  = btn?.querySelector('.icon-menu')  as HTMLElement | null
  const iconClose = btn?.querySelector('.icon-close') as HTMLElement | null
  const header = document.getElementById('site-header')

  btn?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false'
    menu?.setAttribute('aria-hidden', String(isOpen))
    btn.setAttribute('aria-expanded', String(!isOpen))
    btn.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten')
    if (iconMenu)  iconMenu.style.display  = isOpen ? 'block' : 'none'
    if (iconClose) iconClose.style.display = isOpen ? 'none'  : 'block'
  })

  window.addEventListener('scroll', () => {
    header?.classList.toggle('header-scrolled', window.scrollY > 10)
  }, { passive: true })
</script>

<style>
  /* ── Dark nav bar ─────────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-charcoal);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: box-shadow var(--transition-base);
  }

  .site-header.header-scrolled {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  /* ── Layout ────────────────────────────────────────────────────────────── */
  .header-inner {
    display: flex;
    align-items: center;
    height: 4.5rem;
    gap: 1.5rem;
  }

  /* ── Logo ──────────────────────────────────────────────────────────────── */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header-logo:hover { text-decoration: none; }

  .logo-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .logo-wordmark {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: -0.025em;
    line-height: 1;
    white-space: nowrap;
  }

  .logo-wordmark-accent {
    color: var(--color-primary-400);
  }

  .logo-wordmark-tld {
    font-size: 0.75em;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 767px) {
    .header-inner { height: 4rem; }
    .logo-icon { width: 38px; height: 38px; }
    .logo-wordmark { font-size: 1.1rem; }
  }

  /* ── Desktop nav ───────────────────────────────────────────────────────── */
  .header-nav { flex: 1; }

  .nav-list {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-list { display: flex; align-items: center; }
  }

  .nav-link {
    display: block;
    padding: 0.45rem 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    border-radius: var(--radius-md);
    position: relative;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: var(--color-primary-400);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* ── Login ghost button ────────────────────────────────────────────────── */
  .header-login {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.45rem 0.875rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.15);
    white-space: nowrap;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  @media (min-width: 768px) {
    .header-login { display: inline-flex; }
  }

  .header-login:hover {
    color: rgba(255, 255, 255, 0.95);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  /* ── CTA button (inherits .btn-primary from global) ─────────────────── */
  .header-cta {
    display: none;
    padding: 0.5rem 1.125rem;
    font-size: 0.875rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .header-cta { display: inline-flex; }
  }

  /* ── Mobile hamburger ──────────────────────────────────────────────────── */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.7);
    margin-left: auto;
    transition: color var(--transition-fast);
  }

  .mobile-menu-btn:hover { color: rgba(255, 255, 255, 0.95); }

  @media (min-width: 768px) {
    .mobile-menu-btn { display: none; }
  }

  /* ── Mobile menu ───────────────────────────────────────────────────────── */
  .mobile-menu {
    display: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--color-charcoal);
  }

  .mobile-menu[aria-hidden="false"] { display: block; }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 0;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .mobile-link:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  .mobile-cta {
    display: block;
    margin: 0.5rem 1.25rem 0.75rem;
    padding: 0.875rem 1.25rem;
    background: var(--color-primary-500);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md);
    text-align: center;
    transition: background var(--transition-fast);
  }

  .mobile-cta:hover {
    background: var(--color-primary-600);
    text-decoration: none;
    color: var(--color-white);
  }

  .mobile-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 0.25rem 1.25rem;
  }

  .mobile-login {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .mobile-login:hover {
    color: var(--color-primary-300);
    text-decoration: none;
  }
</style>

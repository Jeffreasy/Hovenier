---
import { NAV_LINKS, SITE } from '../../lib/constants'
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label={`${SITE.name} – homepage`}>
      <img
        src="/tuinhub-logo.jpg"
        alt={SITE.name}
        class="logo-img logo-img--desktop"
        width="40"
        height="40"
        loading="eager"
      />
      <img
        src="/tuinhub-logo.jpg"
        alt={SITE.name}
        class="logo-img logo-img--mobile"
        width="32"
        height="32"
        loading="eager"
      />
    </a>

    <!-- Desktop navigation -->
    <nav class="header-nav" aria-label="Hoofdnavigatie">
      <ul class="nav-list" role="list">
        {NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hovenier login (desktop) -->
    <a href="/inloggen" class="header-login" aria-label="Inloggen als hovenier">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Hovenier inloggen
    </a>

    <!-- Desktop CTA -->
    <a href="/offerte" class="header-cta">
      Gratis offertes
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      class="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu openen"
      id="mobile-menu-btn"
      type="button"
    >
      <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="navigation" aria-label="Mobiele navigatie">
    <ul role="list">
      {NAV_LINKS.map((link) => (
        <li>
          <a href={link.href} class="mobile-link">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/offerte" class="mobile-cta">
          Gratis offertes aanvragen →
        </a>
      </li>
      <li class="mobile-divider" aria-hidden="true"></li>
      <li>
        <a href="/inloggen" class="mobile-login">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Hovenier inloggen
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn    = document.getElementById('mobile-menu-btn')
  const menu   = document.getElementById('mobile-menu')
  const iconMenu  = btn?.querySelector('.icon-menu')  as HTMLElement | null
  const iconClose = btn?.querySelector('.icon-close') as HTMLElement | null
  const header = document.getElementById('site-header')

  btn?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false'
    menu?.setAttribute('aria-hidden', String(isOpen))
    btn.setAttribute('aria-expanded', String(!isOpen))
    btn.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten')
    if (iconMenu)  iconMenu.style.display  = isOpen ? 'block' : 'none'
    if (iconClose) iconClose.style.display = isOpen ? 'none'  : 'block'
  })

  window.addEventListener('scroll', () => {
    header?.classList.toggle('header-scrolled', window.scrollY > 20)
  }, { passive: true })
</script>

<style>
  /* ── Glass nav bar ─────────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(13, 31, 18, 0.55);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    transition: background var(--transition-base), box-shadow var(--transition-base);
  }

  .site-header.header-scrolled {
    background: rgba(13, 31, 18, 0.85);
    box-shadow: 0 4px 32px rgba(0,0,0,0.40);
    border-bottom-color: rgba(255,255,255,0.10);
  }

  /* ── Layout ────────────────────────────────────────────────────────────── */
  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    gap: 1.5rem;
  }

  /* ── Logo ──────────────────────────────────────────────────────────────── */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Logo afbeeldingen – responsive */
  .logo-img {
    display: block;
    height: 32px;
    width: auto;
    object-fit: contain;
  }

  /* Desktop: horizontaal logo zichtbaar, icon verborgen */
  .logo-img--desktop { display: block; }
  .logo-img--mobile  { display: none;  }

  /* ── Desktop nav ───────────────────────────────────────────────────────── */
  .header-nav { flex: 1; }

  .nav-list {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.125rem;
  }

  @media (min-width: 768px) {
    .nav-list { display: flex; align-items: center; }
  }

  .nav-link {
    display: block;
    padding: 0.45rem 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(237,242,236,0.65);
    text-decoration: none;
    border-radius: var(--radius-md);
    position: relative;
    transition: color 0.2s ease-out, background 0.2s ease-out;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 1.5px;
    background: var(--color-secondary);
    box-shadow: 0 0 8px rgba(196,169,106,0.60);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover {
    color: #EDF2EC;
    background: rgba(255,255,255,0.05);
    text-decoration: none;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* ── Login ghost button ────────────────────────────────────────────────── */
  .header-login {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.45rem 0.875rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(237,242,236,0.50);
    text-decoration: none;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.11);
    white-space: nowrap;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  @media (min-width: 768px) {
    .header-login { display: inline-flex; }
    /* Desktop: toon horizontaal logo, verberg icon */
    .logo-img--desktop { display: block; height: 36px; }
    .logo-img--mobile  { display: none;  }
  }

  /* Mobiel: verberg horizontaal logo, toon icon */
  @media (max-width: 767px) {
    .logo-img--desktop { display: none;  }
    .logo-img--mobile  { display: block; height: 28px; }
  }

  .header-login:hover {
    color: #EDF2EC;
    border-color: rgba(196,169,106,0.45);
    background: rgba(196,169,106,0.08);
    text-decoration: none;
  }

  /* ── CTA button ────────────────────────────────────────────────────────── */
  .header-cta {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.125rem;
    background: var(--color-secondary);
    color: #1C1400;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: 0 2px 12px rgba(196,169,106,0.25);
    transition: all var(--transition-fast);
  }

  @media (min-width: 768px) {
    .header-cta { display: inline-flex; }
  }

  .header-cta:hover {
    background: var(--color-secondary-dark);
    box-shadow:
      0 6px 24px rgba(196,169,106,0.45),
      0 2px 8px  rgba(196,169,106,0.25);
    transform: translateY(-2px) scale(1.02);
    text-decoration: none;
    color: #1C1400;
  }

  .header-cta:active {
    transform: scale(0.97);
    box-shadow: 0 2px 8px rgba(196,169,106,0.20);
    transition-duration: 0.08s;
  }

  /* ── Mobile hamburger ──────────────────────────────────────────────────── */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(237,242,236,0.70);
    margin-left: auto;
    transition: color var(--transition-fast);
  }

  .mobile-menu-btn:hover { color: #EDF2EC; }

  @media (min-width: 768px) {
    .mobile-menu-btn { display: none; }
  }

  /* ── Mobile menu ───────────────────────────────────────────────────────── */
  .mobile-menu {
    display: none;
    border-top: 1px solid rgba(255,255,255,0.07);
    background: rgba(13, 31, 18, 0.97);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .mobile-menu[aria-hidden="false"] { display: block; }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 0;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: rgba(237,242,236,0.65);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .mobile-link:hover {
    color: #EDF2EC;
    background: rgba(255,255,255,0.05);
    text-decoration: none;
  }

  .mobile-cta {
    display: block;
    margin: 0.5rem 1.25rem 0.75rem;
    padding: 0.875rem 1.25rem;
    background: var(--color-secondary);
    color: #1C1400;
    font-family: var(--font-heading);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md);
    text-align: center;
    box-shadow: 0 2px 12px rgba(196,169,106,0.25);
    transition: all var(--transition-fast);
  }

  .mobile-cta:hover {
    background: var(--color-secondary-dark);
    text-decoration: none;
    color: #1C1400;
  }

  .mobile-divider {
    height: 1px;
    background: rgba(255,255,255,0.07);
    margin: 0.25rem 1.25rem;
  }

  .mobile-login {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(237,242,236,0.38);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .mobile-login:hover {
    color: rgba(196,169,106,0.85);
    text-decoration: none;
  }
</style>

          <path d="M551.59 157.88c9.77.51 27.54 3.89 37.08 5.92 43.72 9.3 83.19 26.13 120.21 51.13 8.04 5.43 20.57 13.94 27.13 20.97l-3.03 3.42c-1.07 1.33-2.37 2.69-3.53 3.97C683.77 206.43 627.79 180.26 569.67 170.99c-6.04-.97-12.14-1.79-18.21-2.62l.13-10.49Z"/>

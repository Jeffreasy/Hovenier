---
import { NAV_LINKS, SITE } from '../../lib/constants'
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label={`${SITE.name} - homepage`}>
      <img
        src="/tuinhub-logo-horizontal-dark.svg"
        alt={SITE.name}
        class="logo-img logo-img--desktop"
        loading="eager"
      />
      <img
        src="/tuinhub-logo-horizontal-dark.svg"
        alt={SITE.name}
        class="logo-img logo-img--mobile"
        loading="eager"
      />
    </a>

    <!-- Desktop navigation -->
    <nav class="header-nav" aria-label="Hoofdnavigatie">
      <ul class="nav-list" role="list">
        {NAV_LINKS.filter(l => l.href !== '/offerte').map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop: Hovenier login -->
    <a href="/inloggen" class="header-login" aria-label="Inloggen als hovenier">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      Hovenier inloggen
    </a>

    <!-- Desktop CTA -->
    <a href="/offerte" class="header-cta btn-primary">
      Gratis offerte
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      class="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu openen"
      id="mobile-menu-btn"
      type="button"
    >
      <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="navigation" aria-label="Mobiele navigatie">
    <ul role="list">
      {NAV_LINKS.filter(l => l.href !== '/offerte').map((link) => (
        <li>
          <a href={link.href} class="mobile-link">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/offerte" class="mobile-cta">
          Gratis offerte aanvragen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:inline;vertical-align:middle;margin-left:0.25rem">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </li>
      <li class="mobile-divider" aria-hidden="true"></li>
      <li>
        <a href="/inloggen" class="mobile-login">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Hovenier inloggen
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn    = document.getElementById('mobile-menu-btn')
  const menu   = document.getElementById('mobile-menu')
  const iconMenu  = btn?.querySelector('.icon-menu')  as HTMLElement | null
  const iconClose = btn?.querySelector('.icon-close') as HTMLElement | null
  const header = document.getElementById('site-header')

  btn?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false'
    menu?.setAttribute('aria-hidden', String(isOpen))
    btn.setAttribute('aria-expanded', String(!isOpen))
    btn.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten')
    if (iconMenu)  iconMenu.style.display  = isOpen ? 'block' : 'none'
    if (iconClose) iconClose.style.display = isOpen ? 'none'  : 'block'
  })

  window.addEventListener('scroll', () => {
    header?.classList.toggle('header-scrolled', window.scrollY > 10)
  }, { passive: true })
</script>

<style>
  /* ── Dark nav bar ─────────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-charcoal);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: box-shadow var(--transition-base);
  }

  .site-header.header-scrolled {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  /* ── Layout ────────────────────────────────────────────────────────────── */
  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    gap: 1.5rem;
  }

  /* ── Logo ──────────────────────────────────────────────────────────────── */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    display: block;
    height: 32px;
    width: auto;
    object-fit: contain;
  }

  .logo-img--desktop { display: block; }
  .logo-img--mobile  { display: none;  }

  /* ── Desktop nav ───────────────────────────────────────────────────────── */
  .header-nav { flex: 1; }

  .nav-list {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-list { display: flex; align-items: center; }
  }

  .nav-link {
    display: block;
    padding: 0.45rem 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    border-radius: var(--radius-md);
    position: relative;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: var(--color-primary-400);
    border-radius: 1px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* ── Login ghost button ────────────────────────────────────────────────── */
  .header-login {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.45rem 0.875rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.15);
    white-space: nowrap;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  @media (min-width: 768px) {
    .header-login { display: inline-flex; }
    .logo-img--desktop { display: block; height: 36px; }
    .logo-img--mobile  { display: none;  }
  }

  @media (max-width: 767px) {
    .logo-img--desktop { display: none;  }
    .logo-img--mobile  { display: block; height: 28px; }
  }

  .header-login:hover {
    color: rgba(255, 255, 255, 0.95);
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  /* ── CTA button (inherits .btn-primary from global) ─────────────────── */
  .header-cta {
    display: none;
    padding: 0.5rem 1.125rem;
    font-size: 0.875rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .header-cta { display: inline-flex; }
  }

  /* ── Mobile hamburger ──────────────────────────────────────────────────── */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.7);
    margin-left: auto;
    transition: color var(--transition-fast);
  }

  .mobile-menu-btn:hover { color: rgba(255, 255, 255, 0.95); }

  @media (min-width: 768px) {
    .mobile-menu-btn { display: none; }
  }

  /* ── Mobile menu ───────────────────────────────────────────────────────── */
  .mobile-menu {
    display: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--color-charcoal);
  }

  .mobile-menu[aria-hidden="false"] { display: block; }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 0;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .mobile-link:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  .mobile-cta {
    display: block;
    margin: 0.5rem 1.25rem 0.75rem;
    padding: 0.875rem 1.25rem;
    background: var(--color-primary-500);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md);
    text-align: center;
    transition: background var(--transition-fast);
  }

  .mobile-cta:hover {
    background: var(--color-primary-600);
    text-decoration: none;
    color: var(--color-white);
  }

  .mobile-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 0.25rem 1.25rem;
  }

  .mobile-login {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .mobile-login:hover {
    color: var(--color-primary-300);
    text-decoration: none;
  }
</style>

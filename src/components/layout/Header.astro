---
import { NAV_LINKS, SITE } from '../../lib/constants'
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label={`${SITE.name} – homepage`}>
      <span class="logo-icon" aria-hidden="true">🌿</span>
      <span class="logo-text">{SITE.name}</span>
    </a>

    <!-- Desktop navigation -->
    <nav class="header-nav" aria-label="Hoofdnavigatie">
      <ul class="nav-list" role="list">
        {NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop CTA -->
    <a href="/offerte" class="header-cta">
      Gratis offertes
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Mobile hamburger -->
    <button
      class="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu openen"
      id="mobile-menu-btn"
      type="button"
    >
      <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="navigation" aria-label="Mobiele navigatie">
    <ul role="list">
      {NAV_LINKS.map((link) => (
        <li>
          <a href={link.href} class="mobile-link">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/offerte" class="mobile-cta">
          Gratis offertes aanvragen →
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  const iconMenu = btn?.querySelector('.icon-menu') as HTMLElement | null
  const iconClose = btn?.querySelector('.icon-close') as HTMLElement | null
  const header = document.getElementById('site-header')

  // Mobile menu toggle
  btn?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false'
    menu?.setAttribute('aria-hidden', String(isOpen))
    btn.setAttribute('aria-expanded', String(!isOpen))
    btn.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten')
    if (iconMenu) iconMenu.style.display = isOpen ? 'block' : 'none'
    if (iconClose) iconClose.style.display = isOpen ? 'none' : 'block'
  })

  // Scroll shadow
  window.addEventListener('scroll', () => {
    header?.classList.toggle('header-scrolled', window.scrollY > 20)
  }, { passive: true })
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-neutral-200);
    transition: box-shadow var(--transition-base);
  }

  .site-header.header-scrolled {
    box-shadow: var(--shadow-md);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 4rem;
    gap: 2rem;
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon { font-size: 1.375rem; }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary-dark);
  }

  .header-nav { flex: 1; }

  .nav-list {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-list {
      display: flex;
      align-items: center;
    }
  }

  .nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-neutral-700);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-light);
    text-decoration: none;
  }

  .header-cta {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    background-color: var(--color-secondary);
    color: var(--color-neutral-900);
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    border: 2px solid var(--color-secondary);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  @media (min-width: 768px) {
    .header-cta { display: inline-flex; }
  }

  .header-cta:hover {
    background-color: var(--color-secondary-dark);
    border-color: var(--color-secondary-dark);
    text-decoration: none;
  }

  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-neutral-900);
    margin-left: auto;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn { display: none; }
  }

  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-neutral-200);
    background: white;
  }

  .mobile-menu[aria-hidden="false"] {
    display: block;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.75rem 0;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-neutral-900);
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .mobile-link:hover {
    background-color: var(--color-primary-light);
    text-decoration: none;
  }

  .mobile-cta {
    display: block;
    margin: 0.75rem 1.25rem;
    padding: 0.75rem 1.25rem;
    background-color: var(--color-secondary);
    color: var(--color-neutral-900);
    font-family: var(--font-heading);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-md);
    text-align: center;
  }
</style>

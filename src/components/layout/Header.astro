          <path d="M728.53 781.87l.69.06c1.46 1.03 4.78 5.68 6.03 7.33-8.01 7.59-20.09 15.8-29.27 21.86-44.22 29.53-94.79 48.19-147.59 54.47-2.13.35-4.79.59-6.98.85l-.06-10.77c55.48-5.49 108.95-26.33 155.06-57.33 7.46-5.02 14.81-11.09 22.12-16.47Z"/>
          <path d="M856.63 550.39l10.1.04c-.6 13.84-3.44 28.34-6.56 41.8-11.55 52.06-35.75 100.47-70.45 140.95l-.88.95c-2.27-.05-6.07-4.27-7.9-6l.05-.02c33.69-40.3 57.39-88.07 69.08-139.35 2.48-10.6 5.76-27.6 6.55-38.37Z"/>

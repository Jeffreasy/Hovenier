---
import { NAV_LINKS, SITE } from '../../lib/constants'
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label={`${SITE.name} - homepage`}>
      <svg class="logo-icon" viewBox="0 0 1024 1024" aria-hidden="true" style="color:white;">
        <g fill="currentColor">
